---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="株式会社ダウイン モバイル事業部 採用サイト" />
  <title>{title} | ダウイン モバイル事業部</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
</head>
<body class="font-['Noto_Sans_JP'] text-gray-900 bg-white">

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-bold text-lg tracking-wide">
        <span class="text-blue-600">DAWIN</span> Mobile
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="/about" class="hover:text-blue-600 transition-colors">ABOUT</a>
        <a href="/interview" class="hover:text-blue-600 transition-colors">INTERVIEW</a>
        <a href="/culture" class="hover:text-blue-600 transition-colors">CULTURE</a>
        <a href="/blog" class="hover:text-blue-600 transition-colors">BLOG</a>
        <a href="/recruit" class="hover:text-blue-600 transition-colors">RECRUIT</a>
        <a href="/contact" class="hover:text-blue-600 transition-colors">CONTACT</a>
      </nav>
      <a href="/recruit" class="bg-blue-600 text-white text-sm font-bold px-5 py-2.5 rounded-full hover:bg-blue-700 transition-colors">
        エントリーはこちら →
      </a>
    </div>
  </header>

  <!-- Mobile nav -->
  <div class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 flex">
    <a href="/" class="flex-1 py-3 text-center text-xs text-gray-600">HOME</a>
    <a href="/interview" class="flex-1 py-3 text-center text-xs text-gray-600">INTERVIEW</a>
    <a href="/culture" class="flex-1 py-3 text-center text-xs text-gray-600">CULTURE</a>
    <a href="/contact" class="flex-1 py-3 text-center text-xs text-gray-600">CONTACT</a>
    <a href="/recruit" class="flex-1 py-3 text-center text-xs font-bold text-white bg-blue-600">ENTRY</a>
  </div>

  <main class="pt-16 pb-16 md:pb-0">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 text-sm py-10 px-6 text-center">
    <p class="font-bold text-white mb-2">株式会社ダウイン モバイル事業部</p>
    <p class="mb-6">〒106-0031 東京都港区西麻布1-14-1 井門西麻布ビル3F</p>
    <p class="text-xs text-gray-600">© 2025 DAWIN Co., Ltd. All rights reserved.</p>
  </footer>

</body>
</html>
