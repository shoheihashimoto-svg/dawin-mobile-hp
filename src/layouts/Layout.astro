---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = '株式会社ダウイン モバイル事業部 採用サイト。未経験歓迎・インセンティブ充実。関東・福岡でモバイルイベントスタッフ募集中。',
  ogImage = '/og-default.jpg',
} = Astro.props;
const siteUrl = 'https://mobile.dawin.co.jp';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | ダウイン モバイル事業部</title>
  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ダウイン モバイル事業部" />
  <meta property="og:title" content={`${title} | ダウイン モバイル事業部`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ダウイン モバイル事業部`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
</head>
<body class="font-['Noto_Sans_JP'] text-gray-900 bg-white">

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-bold text-lg tracking-wide">
        <span class="text-blue-600">DAWIN</span> Mobile
      </a>
      <div class="flex items-center gap-2">
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="/about" class="hover:text-blue-600 transition-colors">ABOUT</a>
          <a href="/interview" class="hover:text-blue-600 transition-colors">INTERVIEW</a>
          <a href="/culture" class="hover:text-blue-600 transition-colors">CULTURE</a>
          <a href="/blog" class="hover:text-blue-600 transition-colors">BLOG</a>
          <a href="/recruit" class="hover:text-blue-600 transition-colors">RECRUIT</a>
          <a href="/contact" class="hover:text-blue-600 transition-colors">CONTACT</a>
        </nav>
        <a href="https://lin.ee/Z7jiZg1" target="_blank" rel="noopener" class="hidden md:inline-block border border-green-500/50 text-green-600 text-sm font-bold px-5 py-2.5 rounded-full hover:bg-green-50 transition-colors">
          応募前にLINEで相談
        </a>
        <!-- LINE丸アイコン（モバイルのみ） -->
        <a href="https://lin.ee/Z7jiZg1" target="_blank" rel="noopener"
           class="md:hidden w-9 h-9 flex items-center justify-center rounded-full bg-[#06C755] text-white flex-shrink-0 active:scale-95 transition-transform"
           aria-label="LINEで相談">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
        </a>
        <a href="/recruit" class="bg-blue-600 text-white text-sm font-bold px-4 py-2 md:px-5 md:py-2.5 rounded-full hover:bg-blue-700 transition-colors whitespace-nowrap">
          <span class="md:hidden">ENTRY</span>
          <span class="hidden md:inline">エントリーはこちら →</span>
        </a>
        <!-- ハンバーガーボタン（モバイルのみ・一番右） -->
        <button id="ham-btn" class="md:hidden p-2 text-gray-600 hover:text-blue-600 transition-colors" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-drawer">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile LINE floating button -->
  <a href="https://lin.ee/Z7jiZg1" target="_blank" rel="noopener"
     class="md:hidden fixed bottom-[4.5rem] right-4 z-40 flex flex-col items-center justify-center w-14 h-14 rounded-full bg-[#06C755] text-white shadow-lg shadow-green-900/30 active:scale-95 transition-transform">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
    </svg>
    <span class="text-[9px] font-bold leading-none mt-0.5">LINE</span>
  </a>

  <!-- Mobile nav -->
  <div class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 flex">
    <a href="/" class="flex-1 py-3 text-center text-xs text-gray-600">HOME</a>
    <a href="/about" class="flex-1 py-3 text-center text-xs text-gray-600">ABOUT</a>
    <a href="/interview" class="flex-1 py-3 text-center text-[10px] text-gray-600">INTERVIEW</a>
    <a href="/culture" class="flex-1 py-3 text-center text-xs text-gray-600">CULTURE</a>
    <a href="/recruit" class="flex-1 py-3 text-center text-xs font-bold text-white bg-blue-600">ENTRY</a>
  </div>

  <!-- モバイルドロワー（スマホのみ） -->
  <div id="mobile-drawer" class="md:hidden fixed inset-0 z-[200] pointer-events-none" aria-hidden="true" role="dialog" aria-modal="true" aria-label="ナビゲーションメニュー">
    <!-- 背景オーバーレイ -->
    <div id="drawer-backdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
    <!-- パネル（右からスライドイン） -->
    <div id="drawer-panel" class="absolute top-0 right-0 h-full w-72 bg-white transform translate-x-full transition-transform duration-300 ease-in-out shadow-2xl flex flex-col">
      <!-- パネルヘッダー -->
      <div class="flex items-center justify-between px-6 h-16 border-b border-gray-100 flex-shrink-0">
        <span class="font-bold text-lg"><span class="text-blue-600">DAWIN</span> Mobile</span>
        <button id="drawer-close-btn" class="p-2 -mr-2 text-gray-400 hover:text-gray-700 transition-colors" aria-label="メニューを閉じる">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <!-- ナビリンク -->
      <nav class="flex flex-col px-4 py-4 gap-0.5 flex-1 overflow-y-auto">
        <a href="/" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">HOME</a>
        <a href="/about" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">ABOUT</a>
        <a href="/interview" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">INTERVIEW</a>
        <a href="/culture" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">CULTURE</a>
        <a href="/blog" class="flex items-center justify-between py-3 px-4 text-blue-600 font-bold text-sm tracking-widest bg-blue-50 rounded-xl">
          BLOG
          <span class="text-[9px] bg-blue-600 text-white px-2 py-0.5 rounded-full font-bold tracking-normal">NEW</span>
        </a>
        <a href="/recruit" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">RECRUIT</a>
        <a href="/contact" class="py-3 px-4 text-gray-600 font-bold text-sm tracking-widest hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">CONTACT</a>
      </nav>
      <!-- 下部 CTA -->
      <div class="px-4 pb-24 pt-4 border-t border-gray-100 flex flex-col gap-3 flex-shrink-0">
        <a href="/recruit" class="block text-center bg-blue-600 text-white font-black text-sm px-6 py-4 rounded-2xl hover:bg-blue-700 transition-colors">
          エントリーはこちら →
        </a>
        <a href="https://lin.ee/Z7jiZg1" target="_blank" rel="noopener" class="block text-center border border-green-500 text-green-600 font-bold text-sm px-6 py-3 rounded-2xl hover:bg-green-50 transition-colors">
          LINEで相談する
        </a>
      </div>
    </div>
  </div>

  <main class="pt-16 pb-16 md:pb-0">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 text-sm py-12 px-6 text-center">
    <p class="font-bold text-white mb-2">株式会社ダウイン モバイル事業部</p>
    <p class="mb-6">〒106-0031 東京都港区西麻布1-14-1<br />井門西麻布ビル3F</p>
    <nav class="hidden md:flex justify-center gap-6 mb-6 text-xs">
      <a href="/about" class="hover:text-white transition-colors">ABOUT</a>
      <a href="/interview" class="hover:text-white transition-colors">INTERVIEW</a>
      <a href="/culture" class="hover:text-white transition-colors">CULTURE</a>
      <a href="/blog" class="hover:text-white transition-colors">BLOG</a>
      <a href="/recruit" class="hover:text-white transition-colors">RECRUIT</a>
      <a href="/contact" class="hover:text-white transition-colors">CONTACT</a>
    </nav>
    <p class="text-xs text-gray-600">© 2026 DAWIN Co., Ltd. All rights reserved.</p>
  </footer>


<script>
  (function() {
    const hamBtn   = document.getElementById('ham-btn');
    const closeBtn = document.getElementById('drawer-close-btn');
    const backdrop = document.getElementById('drawer-backdrop');
    const panel    = document.getElementById('drawer-panel');
    const drawer   = document.getElementById('mobile-drawer');
    if (!hamBtn || !drawer) return;

    function openDrawer() {
      drawer.classList.remove('pointer-events-none');
      drawer.setAttribute('aria-hidden', 'false');
      backdrop!.classList.remove('opacity-0');
      panel!.classList.remove('translate-x-full');
      hamBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      backdrop!.classList.add('opacity-0');
      panel!.classList.add('translate-x-full');
      hamBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      setTimeout(() => {
        drawer.classList.add('pointer-events-none');
        drawer.setAttribute('aria-hidden', 'true');
      }, 300);
    }

    hamBtn.addEventListener('click', openDrawer);
    closeBtn!.addEventListener('click', closeDrawer);
    backdrop!.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });
  })();
</script>
</body>
</html>
