---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ABOUT">
<style>
  .diamond-card {
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
    position: relative;
  }
  .card-shine {
    position: absolute;
    inset: -20px;
    background: linear-gradient(108deg, transparent 30%, rgba(255,255,255,0) 40%, rgba(255,255,255,0.88) 50%, rgba(255,255,255,0) 60%, transparent 70%);
    transform: translateX(-130%);
    animation: cardShine 3.8s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  @keyframes cardShine {
    0%   { transform: translateX(-130%); opacity: 0; }
    4%   { opacity: 1; }
    30%  { transform: translateX(130%);  opacity: 1; }
    34%  { opacity: 0; }
    100% { transform: translateX(130%);  opacity: 0; }
  }
  @keyframes cardStarPop {
    0%   { opacity: 0;   transform: scale(0.15) rotate(-20deg); }
    20%  { opacity: 1;   transform: scale(1.2)  rotate(5deg); }
    70%  { opacity: 0.8; transform: scale(0.95) rotate(12deg); }
    100% { opacity: 0;   transform: scale(0.3)  rotate(25deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .card-shine { animation: none; }
  }
  .about-card-wrap {
    animation: aboutCardAmbient 6s ease-in-out infinite;
  }
  @keyframes aboutCardAmbient {
    0%, 100% { filter: drop-shadow(0 0  0px rgba(59,130,246,0.0)); }
    50%       { filter: drop-shadow(0 0 18px rgba(96,165,250,0.42)); }
  }
</style>


<!-- Hero -->
<section class="hero-bg relative py-32 px-6 text-white text-center overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-indigo-500/20 rounded-full blur-3xl"></div>
  </div>
  <div class="absolute inset-0 opacity-5"
    style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <p class="text-blue-300 font-bold tracking-[0.3em] text-xs uppercase mb-6">About Us</p>
    <h1 class="text-4xl md:text-6xl font-black mb-6">私たちについて</h1>
    <p class="text-blue-100/80 text-base md:text-lg">原石を削り合い、磨き合い、<br class="sm:hidden" />輝いていく。<br />それがダウイン<br class="sm:hidden" />モバイル事業部のスタイル。</p>
  </div>
</section>

<!-- ミッション -->
<section class="py-24 px-6 bg-gray-950 text-white">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-blue-400 font-bold text-xs tracking-widest uppercase mb-4">Mission</p>
    <h2 class="text-3xl md:text-4xl font-black mb-10">私たちのミッション</h2>
    <p class="text-2xl md:text-3xl font-black text-white leading-relaxed mb-8">
      「自ら掴んだチャンスが、自分を変える。<br />
      <span class="text-blue-400">隣の仲間を全力で思いやる。</span>」
    </p>
    <p class="text-gray-400 text-base leading-relaxed max-w-2xl mx-auto">
      イベントの最前線で、原石のようなスタッフひとりひとりが磨かれ、輝いていける環境をつくる。
      削り合い、高め合いながら、全員が「なりたい自分」に近づけるチームであり続けることが、私たちの使命です。
    </p>
  </div>
</section>

<!-- ティッカー -->
<div class="bg-blue-600 py-4 overflow-hidden whitespace-nowrap">
  <div class="ticker-track inline-flex gap-12 text-white font-bold text-sm tracking-widest">
    {Array(2).fill(['CHALLENGE', 'GROWTH', 'TEAMWORK', 'PASSION', 'CAREER', 'MOTIVATION', 'MOBILE', 'NOW HIRING']).flat().map((w) => (
      <span>✦ {w}</span>
    ))}
  </div>
</div>

<!-- 事業概要 -->
<section class="py-24 px-6 bg-gray-950 text-white">
  <div class="max-w-4xl mx-auto">
    <p class="text-blue-400 font-bold text-xs tracking-widest uppercase mb-4 text-center">Business</p>
    <h2 class="text-3xl font-black text-center mb-12">事業内容</h2>
    <div class="flex flex-col gap-10">
      <div class="space-y-5">
        <p class="text-gray-300 leading-relaxed">
          携帯キャリアの代理店からイベントを受注し、全国の商業施設でモバイルイベントを運営しています。
        </p>
        <p class="text-gray-300 leading-relaxed">
          私たちのビジネスの核心は「人」。お客様に最高の体験を提供するスタッフを育て、
          チームとして最大限のパフォーマンスを発揮することにこだわっています。
        </p>
        <p class="text-gray-300 leading-relaxed">
          全国規模のイベント実績No.1を誇るまでに成長しました。
        </p>
      </div>
      <div class="border border-white/10 rounded-2xl overflow-hidden"
        style="display: grid; grid-template-columns: 7rem 1fr;">
        {(() => {
          const rows = [
            { label: '会社名',     value: '株式会社ダウイン' },
            { label: '本社所在地', value: '〒661-0976\n兵庫県尼崎市潮江1丁目20番1号\nアミング潮江イースト20-1号棟201C号' },
            { label: '資本金',     value: '9,900万円' },
            { label: '従業員数',   value: '301名（2024年6月1日現在）' },
            { label: 'グループ',   value: '株式会社QLSホールディングス\n（東証グロース市場　証券コード7075）' },
            { label: '事業部所在地', value: '【東京】港区西麻布1-14-1 井門西麻布ビル3F\n\n【福岡】博多区博多駅南1-3-8 博多パールビル605' },
            { label: '事業部規模', value: '社員16名 ＋ アルバイト27名' },
            { label: '事業内容',   value: 'モバイルイベント企画・運営・派遣' },
          ];
          const last = rows.length - 1;
          return rows.map((item, i) => (
            <>
              <div class={`bg-blue-600 text-white text-xs font-bold px-4 py-4 flex items-center border-b border-blue-500 ${i === last ? 'border-b-0' : ''}`}>
                {item.label}
              </div>
              <div class={`px-5 py-4 text-sm text-gray-300 whitespace-pre-line border-b border-white/10 ${i % 2 === 0 ? 'bg-white/5' : 'bg-white/[0.02]'} ${i === last ? 'border-b-0' : ''}`}>
                {item.value}
              </div>
            </>
          ));
        })()}
      </div>
    </div>
  </div>
</section>

<!-- バリュー -->
<section class="py-24 px-6 bg-white">
  <div class="max-w-4xl mx-auto">
    <p class="text-blue-600 font-bold text-xs tracking-widest uppercase mb-4 text-center">Values</p>
    <h2 class="text-2xl md:text-3xl font-black text-center mb-12">大切にしている価値観</h2>
    <div class="grid grid-cols-4 md:grid-cols-3 gap-3 md:gap-6 w-full sm:max-w-2xl mx-auto">
      {[
        {
          title: 'Challenge',
          label: '挑戦',
          body: '原石の才能も、まず動かなければ磨かれない。失敗を恐れず前に出る姿勢が、輝きのはじまり。',
          bg: 'bg-blue-600',
          dimColor: 'text-blue-200',
        },
        {
          title: 'Teamwork',
          label: '削り合い',
          body: '仲間と切磋琢磨することで、互いの面が磨かれる。隣の輝きが、自分の輝きを増す。',
          bg: 'bg-indigo-600',
          dimColor: 'text-indigo-200',
        },
        {
          title: 'Growth',
          label: '輝きへ',
          body: '原石のまま終わらせない。現場での経験と仲間の力で、全員が本来の輝きに近づいていける。',
          bg: 'bg-purple-600',
          dimColor: 'text-purple-200',
        },
      ].map((v, i) => (
        <div class={`about-card-wrap aspect-square ${i === 2 ? 'col-start-2 col-span-2 md:col-start-auto md:col-span-1' : 'col-span-2 md:col-span-1'}`}>
          <div class={`diamond-card w-full h-full ${v.bg} flex flex-col items-center justify-center gap-2`}>
            <div class="text-center w-[56%] relative z-[1]">
              <p class={`${v.dimColor} text-[9px] font-bold tracking-widest uppercase leading-none mb-1`}>{v.title}</p>
              <p class="text-lg font-black text-white leading-tight">{v.label}</p>
            </div>
            <div class="w-[35%] h-px bg-white/25 flex-shrink-0 relative z-[1]"></div>
            <div class="text-center w-[56%] relative z-[1]">
              <p class="text-[8px] text-white/85 leading-relaxed">{v.body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.about-card-wrap').forEach(wrap => {
    (wrap as HTMLElement).style.animationDelay = (Math.random() * 6).toFixed(2) + 's';
  });

  // ─ 星スパークル ─
  (function() {
    const syms   = ['✦', '✧', '✦', '✧', '✦'];
    const colors = ['rgba(255,255,255,0.9)', 'rgba(255,255,255,0.6)', '#e0e7ff', '#c7d2fe', 'rgba(255,255,255,0.75)'];

    function spawnStar(card) {
      const el = document.createElement('span');
      const dur = (0.85 + Math.random() * 0.75).toFixed(2);
      const size = card.clientWidth || 180;
      const pad = size * 0.13;
      el.textContent = syms[Math.floor(Math.random() * syms.length)];
      el.style.cssText = [
        'position:absolute',
        'pointer-events:none',
        'opacity:0',
        'z-index:3',
        'transform-origin:center',
        'line-height:1',
        `left:${(pad + Math.random() * (size - pad * 2)).toFixed(0)}px`,
        `top:${(pad + Math.random() * (size - pad * 2)).toFixed(0)}px`,
        `font-size:${(8 + Math.random() * 11).toFixed(0)}px`,
        `color:${colors[Math.floor(Math.random() * colors.length)]}`,
        `animation:cardStarPop ${dur}s ease-out forwards`,
      ].join(';');
      card.appendChild(el);
      setTimeout(() => el.remove(), parseFloat(dur) * 1000 + 80);
    }

    document.querySelectorAll('.diamond-card').forEach((card, idx) => {
      const delay = idx * 350;
      [delay + 200, delay + 520, delay + 840].forEach(t => setTimeout(() => spawnStar(card), t));
      function loop() {
        spawnStar(card);
        if (Math.random() < 0.38) setTimeout(() => spawnStar(card), 160 + Math.random() * 130);
        setTimeout(loop, 400 + Math.random() * 360);
      }
      setTimeout(loop, delay + 1050);
    });
  })();
</script>

<!-- CTA -->
<section class="relative py-28 px-6 overflow-hidden text-center">
  <div class="hero-bg absolute inset-0"></div>
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="relative z-10">
    <p class="text-blue-300 font-bold tracking-widest text-xs uppercase mb-6">Join Us</p>
    <h2 class="text-2xl md:text-5xl font-black text-white mb-6 leading-tight">
      このチームで、<br class="sm:hidden" />挑戦してみませんか？
    </h2>
    <p class="text-blue-100/80 text-lg mb-12 max-w-xl mx-auto">
      ミッションに共感したなら、まず話を聞きに来てください。
    </p>
    <a href="/recruit"
      class="inline-block bg-white text-blue-900 font-black text-xl px-14 py-5 rounded-full hover:shadow-[0_0_60px_rgba(255,255,255,0.4)] hover:scale-105 transition-all duration-300">
      エントリーしてみる →
    </a>
  </div>
</section>

</Layout>
