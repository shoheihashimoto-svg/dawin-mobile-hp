---
import Layout from '../layouts/Layout.astro';
---
<Layout title="HOME">

<style>
  /* ================= INTRO ================= */
  @keyframes lineUp { from { transform: translateY(115%); } to { transform: translateY(0); } }

  /* ================= HERO ================= */
  .rise { animation: riseUp 1s cubic-bezier(0.22, 1, 0.36, 1) both; }
  @keyframes riseUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .rise-1 { animation-delay: 0.15s; }
  .rise-2 { animation-delay: 0.7s; }
  .rise-3 { animation-delay: 0.85s; }
  .rise-4 { animation-delay: 1s; }

  .hl-1 { animation: lineUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both; }
  .hl-2 { animation: lineUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both; }
  /* hl-3 だけ overflow-hidden 不要のフェード付きバリアント */
  .hl-3 { animation: lineUpFade 1s cubic-bezier(0.22, 1, 0.36, 1) 0.55s both; }
  @keyframes lineUpFade {
    from { transform: translateY(110%); opacity: 0; }
    18%  { opacity: 1; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .fade-in { animation: fadeIn 1.2s ease 1.4s both; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .shine-text {
    background: linear-gradient(105deg, #3b82f6 0%, #93c5fd 25%, #f0f9ff 50%, #93c5fd 75%, #3b82f6 100%);
    background-size: 220% 150%;
    background-position: 0 center;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: sheen 5.5s linear infinite;
  }
  @keyframes sheen { to { background-position: -220% center; } }

  .gem-wrap {
    width: clamp(8rem, 70vw, 14rem);
    aspect-ratio: 4/3;
    animation: gemEnter 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.45s both;
  }
  @media (min-width: 1024px) {
    .gem-wrap {
      width: clamp(9rem, 50vw, 22rem);
      aspect-ratio: 3/4;
    }
  }
  @keyframes gemEnter {
    from { opacity: 0; transform: translateY(46px) scale(0.88); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .gem-glow { animation: glowPulse 6s ease-in-out infinite; }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.3; transform: translateY(-50%) scale(0.9); }
    50%      { opacity: 0.65; transform: translateY(-50%) scale(1.1); }
  }

  .shaft { animation: shaftSway 16s ease-in-out infinite alternate; }
  @keyframes shaftSway {
    from { transform: rotate(20deg) translateX(-40px); opacity: 0.5; }
    to   { transform: rotate(25deg) translateX(40px);  opacity: 1; }
  }

  .spark { position: absolute; border-radius: 9999px; background: #bfdbfe; animation: twinkle 5.5s ease-in-out infinite; }
  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: translateY(0) scale(0.5); }
    50%      { opacity: 0.7; transform: translateY(-20px) scale(1); }
  }

  /* 4点スター スパークル */
  .star-flare {
    position: absolute; pointer-events: none;
    animation: starFlare var(--sd, 3.2s) var(--ss, 0s) ease-in-out infinite;
  }
  @keyframes starFlare {
    0%,100% { opacity:0; transform: scale(0.3) rotate(0deg); }
    45%,55% { opacity:1; transform: scale(1)   rotate(45deg); }
  }

  .spin-slow { animation: spinSlow 90s linear infinite; }
  @keyframes spinSlow { to { transform: rotate(360deg); } }

  .scroll-dot { animation: scrollDot 2.4s cubic-bezier(0.76, 0, 0.24, 1) infinite; }
  @keyframes scrollDot {
    0%   { transform: translateY(0); opacity: 0; }
    15%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(44px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    #intro { display: none !important; }
    * { animation-duration: 0.001s !important; animation-delay: 0s !important; animation-iteration-count: 1 !important; }
  }

  .hex-card {
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
  }
  .hex-card .card-shine {
    position: absolute;
    inset: -20px;
    background: linear-gradient(108deg, transparent 30%, rgba(255,255,255,0) 40%, rgba(255,255,255,0.88) 50%, rgba(255,255,255,0) 60%, transparent 70%);
    transform: translateX(-130%);
    animation: hexCardShine 3.8s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  @keyframes hexCardShine {
    0%   { transform: translateX(-130%); opacity: 0; }
    4%   { opacity: 1; }
    30%  { transform: translateX(130%);  opacity: 1; }
    34%  { opacity: 0; }
    100% { transform: translateX(130%);  opacity: 0; }
  }
  @keyframes hexCardStarPop {
    0%   { opacity: 0;   transform: scale(0.15) rotate(-20deg); }
    20%  { opacity: 1;   transform: scale(1.2)  rotate(5deg); }
    70%  { opacity: 0.8; transform: scale(0.95) rotate(12deg); }
    100% { opacity: 0;   transform: scale(0.3)  rotate(25deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hex-card .card-shine { animation: none; }
  }

  /* ── ダイヤモンド 線順光アニメーション ── */
  .why-diamond-wrap {
    animation: whyDiamondAmbient 4s ease-in-out infinite;
  }
  @keyframes whyDiamondAmbient {
    0%, 100% { filter: drop-shadow(0 0  0px rgba(59,130,246,0.0)); }
    45%, 55% { filter: drop-shadow(0 0 28px rgba(96,165,250,0.65)); }
  }
  .wdgl { animation: whyDiamondLineGlow 4s ease-in-out infinite; }
  .wdgl-1 { animation-delay: 0s;   }
  .wdgl-2 { animation-delay: 0.8s; }
  .wdgl-3 { animation-delay: 1.6s; }
  .wdgl-4 { animation-delay: 2.4s; }
  .wdgl-5 { animation-delay: 3.2s; }
  @keyframes whyDiamondLineGlow {
    0%   { opacity: 0; }
    4%   { opacity: 1; }
    18%  { opacity: 1; }
    24%  { opacity: 0; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .why-diamond-wrap { animation: none; filter: drop-shadow(0 0 14px rgba(96,165,250,0.4)); }
    .wdgl { animation: none; opacity: 0.6; }
  }

</style>

<!-- ===== INTRO OVERLAY ===== -->
<div id="intro" class="fixed inset-0 z-[200] bg-gray-950 overflow-hidden select-none cursor-pointer" aria-hidden="true">
  <canvas id="intro-gem-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
  <div id="intro-white" class="absolute inset-0 bg-white pointer-events-none" style="opacity:0;"></div>
  <button id="intro-skip-btn" class="absolute bottom-8 right-8 z-10 text-white/35 text-[11px] font-bold tracking-[0.3em] uppercase hover:text-white/70 transition-colors pointer-events-none" style="opacity:0;transition:opacity 0.6s;" aria-label="スキップ">SKIP →</button>
</div>

<!-- ===== HERO ===== -->
<section id="hero-section" class="relative min-h-[100svh] flex items-center text-white overflow-hidden bg-gray-950">
  <canvas id="hero-stars" class="absolute inset-0 w-full h-full pointer-events-none" style="opacity:0.45;" aria-hidden="true"></canvas>

  <!-- 背景レイヤー -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- ダイヤ背後の光彩 -->
    <div class="gem-glow absolute right-[4%] top-1/2 w-[640px] h-[640px] rounded-full blur-[130px]" style="background:radial-gradient(circle, rgba(59,130,246,0.5), rgba(37,99,235,0.25) 45%, rgba(30,58,138,0.08) 70%, transparent 85%);"></div>
    <div class="absolute right-[18%] top-[35%] w-64 h-64 rounded-full blur-[80px]" style="background:radial-gradient(circle, rgba(125,211,252,0.2), transparent 70%);"></div>
    <div class="absolute -left-24 top-[16%] w-96 h-96 bg-indigo-700/10 rounded-full blur-[110px]"></div>
    <!-- ライトシャフト -->
    <div class="shaft absolute -top-[30%] left-[16%] w-[26rem] h-[130vh] blur-3xl" style="background:linear-gradient(to bottom, rgba(96,165,250,0.1), rgba(96,165,250,0.02) 55%, transparent);"></div>
    <div class="shaft absolute -top-[30%] left-[46%] w-[18rem] h-[130vh] blur-3xl" style="background:linear-gradient(to bottom, rgba(147,197,253,0.07), transparent 60%); animation-delay:-8s;"></div>
    <!-- グリッド -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(rgba(255,255,255,.6) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.6) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 80% 70% at 50% 45%, black, transparent);-webkit-mask-image:radial-gradient(ellipse 80% 70% at 50% 45%, black, transparent);"></div>
    <!-- 巨大ワイヤーフレーム・ダイヤ -->
    <svg viewBox="0 0 400 480" class="spin-slow absolute -left-52 -bottom-72 w-[42rem] h-[50rem] opacity-[0.05]">
      <polygon points="112,10 288,10 400,175 200,470 0,175" fill="none" stroke="#60a5fa" stroke-width="1"/>
      <line x1="0" y1="175" x2="400" y2="175" stroke="#60a5fa" stroke-width="0.6"/>
      <line x1="112" y1="10" x2="200" y2="470" stroke="#60a5fa" stroke-width="0.4"/>
      <line x1="288" y1="10" x2="200" y2="470" stroke="#60a5fa" stroke-width="0.4"/>
    </svg>
    <!-- 微粒子 -->
    <span class="spark w-1 h-1"   style="left:12%; top:32%;"></span>
    <span class="spark w-1.5 h-1.5" style="left:26%; top:68%; animation-delay:1.4s;"></span>
    <span class="spark w-1 h-1"   style="left:55%; top:20%; animation-delay:2.8s;"></span>
    <span class="spark w-1 h-1"   style="left:70%; top:78%; animation-delay:2s;"></span>
    <span class="spark w-1.5 h-1.5" style="left:88%; top:30%; animation-delay:3.6s;"></span>
    <span class="spark w-0.5 h-0.5" style="left:5%;  top:14%; animation-delay:0.8s;"></span>
    <span class="spark w-1 h-1"   style="left:38%; top:8%;  animation-delay:4.2s;"></span>
    <span class="spark w-0.5 h-0.5" style="left:77%; top:13%; animation-delay:1.9s;"></span>
    <span class="spark w-0.5 h-0.5" style="left:8%;  top:58%; animation-delay:3.1s;"></span>
    <span class="spark w-1 h-1"   style="left:92%; top:55%; animation-delay:0.5s;"></span>
    <span class="spark w-0.5 h-0.5" style="left:18%; top:85%; animation-delay:2.4s;"></span>
    <span class="spark w-1.5 h-1.5" style="left:82%; top:82%; animation-delay:4.8s;"></span>
    <span class="spark w-0.5 h-0.5" style="left:48%; top:88%; animation-delay:1.1s;"></span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full pt-6 pb-6 md:py-28">
    <div class="grid lg:grid-cols-12 gap-2 lg:gap-8 items-center">

      <!-- 左：コピー -->
      <div class="order-1 lg:col-span-7">
        <div class="rise rise-1 flex items-center gap-4 mb-4 md:mb-8">
          <span class="w-12 h-px bg-gradient-to-r from-blue-400 to-transparent"></span>
          <p class="text-blue-400/80 font-bold tracking-[0.4em] text-xs uppercase">Dawin Mobile Division</p>
        </div>
        <h1 class="font-black tracking-tight mb-4 md:mb-8">
          <span class="block overflow-hidden pb-[0.14em] -mb-[0.14em]">
            <span class="hl-1 block leading-none text-white text-[clamp(3rem,8vw,6.5rem)]">Sharpen</span>
          </span>
          <span class="block overflow-hidden pb-[0.14em] -mb-[0.14em]">
            <span class="hl-2 block leading-none text-white text-[clamp(3rem,8vw,6.5rem)]">each other.</span>
          </span>
          <span class="block mt-1">
            <span class="hl-3 shine-text block leading-none pb-[0.15em] text-[clamp(3rem,8vw,6.5rem)]">Shine together.</span>
          </span>
        </h1>
        <p class="rise rise-2 text-blue-200/90 font-semibold text-base md:text-lg tracking-[0.45em] mb-7">削り合い、輝いていけ。</p>
        <p class="rise rise-3 text-gray-400 text-base leading-relaxed mb-11 max-w-md">
          挑戦を楽しみ、仲間を大切にする人たちが集まるチーム。<br />あなたの「成長したい」を、ここで形にしませんか。
        </p>
        <div class="rise rise-4 flex flex-col sm:flex-row sm:flex-wrap gap-4">
          <a href="/recruit"
            class="group relative overflow-hidden rounded-full bg-white px-10 py-4 text-center text-lg font-black text-blue-950 transition-all duration-500 hover:-translate-y-0.5 hover:shadow-[0_0_50px_rgba(96,165,250,0.55)]">
            <span class="relative z-10">採用情報を見る →</span>
            <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-blue-200/70 to-transparent transition-transform duration-700 group-hover:translate-x-full"></span>
          </a>
          <a href="/interview"
            class="rounded-full border border-blue-300/30 px-10 py-4 text-center text-lg font-bold text-white backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-200/80 hover:bg-blue-400/10">
            社員の声を聞く
          </a>
        </div>
      </div>

      <!-- 右：ダイヤモンド（Three.js） / モバイルではテキストの上 -->
      <div class="order-first lg:order-2 lg:col-span-5 flex justify-center items-center">
        <div class="gem-wrap relative">
          <canvas id="gem-canvas" class="absolute inset-0 w-full h-full"></canvas>
          <!-- WebGL非対応デバイス用フォールバック -->
          <div id="gem-fallback" class="absolute inset-0 hidden items-center justify-center">
            <svg viewBox="0 0 200 240" class="w-2/3 opacity-60" aria-hidden="true">
              <defs>
                <linearGradient id="gfGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.7"/>
                  <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0.3"/>
                </linearGradient>
              </defs>
              <polygon points="100,8 192,78 100,232 8,78" fill="url(#gfGrad)" stroke="#60a5fa" stroke-width="1.5"/>
              <polygon points="100,8 150,78 100,148 50,78" fill="none" stroke="#93c5fd" stroke-width="0.8" opacity="0.6"/>
              <line x1="8" y1="78" x2="192" y2="78" stroke="#60a5fa" stroke-width="0.8" opacity="0.5"/>
              <line x1="100" y1="8" x2="100" y2="232" stroke="#60a5fa" stroke-width="0.5" opacity="0.3"/>
            </svg>
          </div>
          <p class="hidden lg:block absolute -right-10 top-6 [writing-mode:vertical-rl] text-[10px] font-semibold uppercase tracking-[0.55em] text-blue-300/40">Diamond cuts diamond</p>
          <!-- スパークル（12個・各周期2倍で密度を維持） -->
          <svg class="star-flare w-4 h-4" style="left:18%;top:22%;--sd:5.8s;--ss:0.0s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-3 h-3" style="left:72%;top:16%;--sd:7.0s;--ss:1.6s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#bfdbfe"/></svg>
          <svg class="star-flare w-5 h-5" style="left:80%;top:52%;--sd:5.2s;--ss:2.8s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-3 h-3" style="left:10%;top:60%;--sd:8.2s;--ss:0.8s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#93c5fd"/></svg>
          <svg class="star-flare w-4 h-4" style="left:55%;top:78%;--sd:6.0s;--ss:4.2s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-2 h-2" style="left:38%;top:10%;--sd:7.6s;--ss:3.4s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#e0f2fe"/></svg>
          <svg class="star-flare w-3 h-3" style="left:88%;top:28%;--sd:6.4s;--ss:5.2s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-2 h-2" style="left:4%;top:38%;--sd:5.6s;--ss:2.2s"   viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#bfdbfe"/></svg>
          <svg class="star-flare w-4 h-4" style="left:62%;top:88%;--sd:7.2s;--ss:6.0s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-2 h-2" style="left:28%;top:72%;--sd:6.8s;--ss:1.0s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#93c5fd"/></svg>
          <svg class="star-flare w-3 h-3" style="left:90%;top:72%;--sd:8.0s;--ss:4.8s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="white"/></svg>
          <svg class="star-flare w-2 h-2" style="left:46%;top:42%;--sd:5.4s;--ss:7.4s"  viewBox="0 0 20 20"><path d="M10 0L11.2 8.8 20 10l-8.8 1.2L10 20 8.8 11.2 0 10l8.8-1.2Z" fill="#e0f2fe"/></svg>
        </div>
      </div>

    </div>
  </div>

  <!-- スクロール -->
  <div class="fade-in absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-blue-300/60">
    <span class="text-[10px] tracking-[0.4em] font-semibold">SCROLL</span>
    <div class="relative w-px h-14 overflow-hidden bg-blue-300/15">
      <div class="scroll-dot absolute left-0 top-0 w-px h-4 bg-gradient-to-b from-transparent via-blue-200 to-blue-300"></div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

  // ── Shared: Brilliant-cut Diamond Geometry ──────
  function buildDiamond(): THREE.BufferGeometry {
    // N=8: ラウンドブリリアントカット 57-58面
    // クラウン(33): テーブル1 + カイト8 + スター8 + アッパーハーフ16
    // パビリオン(24): ロワーハーフ16 + メイン8
    const N=8, GR=1.0, TR=0.54, CH=0.30, PH=0.84;
    const pos: number[] = [], nor: number[] = [];

    function tri(v0: number[], v1: number[], v2: number[]) {
      const ax=v1[0]-v0[0],ay=v1[1]-v0[1],az=v1[2]-v0[2];
      const bx=v2[0]-v0[0],by=v2[1]-v0[1],bz=v2[2]-v0[2];
      let nx=ay*bz-az*by,ny=az*bx-ax*bz,nz=ax*by-ay*bx;
      const l=Math.sqrt(nx*nx+ny*ny+nz*nz)||1;
      nx/=l;ny/=l;nz/=l;
      pos.push(...v0,...v1,...v2);
      nor.push(nx,ny,nz,nx,ny,nz,nx,ny,nz);
    }
    function quad(a:number[],b:number[],c:number[],d:number[]){tri(a,b,c);tri(a,c,d);}
    const ang=(i:number,n:number,off=0)=>(i/n+off)*Math.PI*2;

    function mkRing(r:number, h:number):[number[][],number[][]] {
      const M:number[][]=[], B:number[][]=[];
      for(let i=0;i<N;i++){
        M.push([r*Math.cos(ang(i,N)), h, r*Math.sin(ang(i,N))]);
        B.push([r*Math.cos(ang(i,N,0.5/N)), h, r*Math.sin(ang(i,N,0.5/N))]);
      }
      return [M,B];
    }
    function zone(aM:number[][], aB:number[][], bM:number[][], bB:number[][]) {
      for(let i=0;i<N;i++) quad(aM[i], aB[i], bB[i], bM[i]);
      for(let i=0;i<N;i++) quad(aB[i], aM[(i+1)%N], bM[(i+1)%N], bB[i]);
    }

    const [tM,tB] = mkRing(TR,   CH);    // テーブルリング
    const [cM,cB] = mkRing(0.84, 0.10);  // クラウン中間リング（アッパーハーフ境界）
    const [gM,gB] = mkRing(GR,   0);     // ガードル
    const [pM,pB] = mkRing(0.65,-0.40);  // パビリオンリング（ロワーハーフ境界）
    const tC=[0,CH,0], cu=[0,-PH,0];

    // テーブル（法線+Y, 1面）
    for(let i=0;i<N;i++) tri(tC, tM[(i+1)%N], tM[i]);
    // カイト8 + スター8（上クラウン）
    for(let i=0;i<N;i++) quad(tM[i], tM[(i+1)%N], cB[i], cM[i]);
    for(let i=0;i<N;i++) tri(tM[(i+1)%N], cM[(i+1)%N], cB[i]);
    // アッパーハーフ16（下クラウン）
    zone(cM, cB, gM, gB);
    // ロワーハーフ16（上パビリオン）
    zone(gM, gB, pM, pB);
    // パビリオンメイン8（収束）
    for(let i=0;i<N;i++) quad(cu, pB[(i-1+N)%N], pM[i], pB[i]);
    const geo=new THREE.BufferGeometry();
    geo.setAttribute('position',new THREE.Float32BufferAttribute(pos,3));
    geo.setAttribute('normal',new THREE.Float32BufferAttribute(nor,3));
    return geo;
  }

  // ── Shared: Material factory ─────────────────────
  function buildMaterial(): THREE.MeshPhysicalMaterial {
    return new THREE.MeshPhysicalMaterial({
      color:              new THREE.Color(0x2563eb),  // vivid blue
      transmission:       0.99,
      ior:                2.42,
      roughness:          0.0,
      metalness:          0.08,
      thickness:          1.3,
      envMapIntensity:    3.5,
      clearcoat:          1.0,
      clearcoatRoughness: 0.0,
      attenuationColor:   new THREE.Color(0x2563eb),  // vivid blue (暗色ではなく鮮やかな青)
      attenuationDistance:0.55,
      dispersion:         3,
      transparent:        true,
    });
  }

  // ── Shared: Renderer factory ─────────────────────
  function buildRenderer(canvas: HTMLCanvasElement): THREE.WebGLRenderer {
    const r = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    r.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    r.toneMapping = THREE.ACESFilmicToneMapping;
    r.toneMappingExposure = 2.2;
    return r;
  }

  function buildEnv(renderer: THREE.WebGLRenderer, scene: THREE.Scene) {
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(renderer), 0.04).texture;
    pmrem.dispose();
  }

  // ── INTRO GEM ────────────────────────────────────
  const intro = document.getElementById('intro') as HTMLElement;
  const isMobile = window.innerWidth < 768;
  const skipIntro = sessionStorage.getItem('intro-shown')
                 || window.matchMedia('(prefers-reduced-motion: reduce)').matches
                 || isMobile;

  if (skipIntro) {
    intro.style.display = 'none';
  } else {
    sessionStorage.setItem('intro-shown', '1');

    const introCanvas = document.getElementById('intro-gem-canvas') as HTMLCanvasElement;
    const ctx2d       = introCanvas.getContext('2d')!;
    const dpr         = Math.min(devicePixelRatio, 2);
    const IW = window.innerWidth, IH = window.innerHeight;

    introCanvas.width  = IW * dpr;
    introCanvas.height = IH * dpr;
    ctx2d.scale(dpr, dpr);

    interface IStar { x:number;y:number;vx:number;vy:number;age:number;maxAge:number;trail:[number,number][];w:number; }

    const iStars:IStar[]=[];

    // Stars: 30% inner→out, 70% edge→across
    function spawnStar() {
      const inner = Math.random() < 0.30;
      let x=0, y=0, vx=0, vy=0;
      const spr = 0.55;

      if (inner) {
        // spawn near center, burst outward
        x = IW*(0.22+Math.random()*0.56);
        y = IH*(0.22+Math.random()*0.56);
        const a = Math.random()*Math.PI*2;
        const spd2 = 160+Math.random()*260;
        vx=Math.cos(a)*spd2; vy=Math.sin(a)*spd2;
        iStars.push({ x,y,vx,vy,age:0, maxAge:0.45+Math.random()*0.65, trail:[], w:0.6+Math.random()*1.8 });
        return;
      }

      const side = Math.floor(Math.random()*4);
      const spd  = 380 + Math.random()*520;
      if (side===0) {
        x=Math.random()*IW; y=-12;
        const a=Math.PI/2+(Math.random()-.5)*spr;
        vx=Math.cos(a)*spd; vy=Math.sin(a)*spd;
      } else if (side===1) {
        x=IW+12; y=Math.random()*IH;
        const a=Math.PI+(Math.random()-.5)*spr;
        vx=Math.cos(a)*spd; vy=Math.sin(a)*spd;
      } else if (side===2) {
        x=Math.random()*IW; y=IH+12;
        const a=-Math.PI/2+(Math.random()-.5)*spr;
        vx=Math.cos(a)*spd; vy=Math.sin(a)*spd;
      } else {
        x=-12; y=Math.random()*IH;
        const a=(Math.random()-.5)*spr;
        vx=Math.cos(a)*spd; vy=Math.sin(a)*spd;
      }
      iStars.push({ x,y,vx,vy,age:0, maxAge:0.32+Math.random()*0.55, trail:[], w:0.7+Math.random()*2.2 });
    }

    // Delay hero CSS animations so elements stay dark until the dissolve completes.
    const iBase = 1.6;
    const iDelays: Record<string,number> = {
      'hl-1':0.25, 'hl-2':0.40, 'hl-3':0.55,
      'rise-1':0.15, 'rise-2':0.70, 'rise-3':0.85, 'rise-4':1.00,
      'fade-in':1.40, 'gem-wrap':0.45,
    };
    Object.entries(iDelays).forEach(([cls,d]) => {
      document.querySelectorAll('.'+cls).forEach(el =>
        ((el as HTMLElement).style.animationDelay = `${(d+iBase).toFixed(2)}s`)
      );
    });

    // Timeline (ms)
    // 0–2400:  shooting stars fly across the dark screen
    // 2400–3200: stars fade out, canvas darkens
    // 3200–6000: intro overlay slowly dissolves → hero text & gem emerge from darkness
    const iP4=1600, iFE=3000;
    let iT0=performance.now(), iPrev=iT0, iRaf2:number, iDone=false;
    let iNxtS=0;

    function doSkip() {
      if (iDone) return;
      iDone=true;
      cancelAnimationFrame(iRaf2);
      intro.style.transition='opacity 0.25s';
      intro.style.opacity='0';
      setTimeout(()=>{ intro.style.display='none'; }, 260);
      Object.entries(iDelays).forEach(([cls,d]) => {
        document.querySelectorAll('.'+cls).forEach(el =>
          ((el as HTMLElement).style.animationDelay = `${(d*0.15+0.04).toFixed(2)}s`)
        );
      });
    }
    intro.addEventListener('click', doSkip);
    intro.addEventListener('touchstart', doSkip, {passive:true});

    ctx2d.fillStyle='rgb(3,7,18)'; ctx2d.fillRect(0,0,IW,IH);

    function iLoop2() {
      iRaf2=requestAnimationFrame(iLoop2);
      const now=performance.now(), ms=now-iT0, dt=Math.min((now-iPrev)/1000,0.05);
      iPrev=now;

      // Spawn stars — active until 2400 ms, tapering off
      if (ms<1200 && ms>iNxtS) {
        spawnStar();
        iNxtS=ms+(ms<300 ? 40+Math.random()*35 : ms<700 ? 65+Math.random()*45 : 110+Math.random()*70);
      }

      // Update stars
      for (let i=iStars.length-1;i>=0;i--) {
        const s=iStars[i]; s.age+=dt; s.x+=s.vx*dt; s.y+=s.vy*dt;
        s.trail.push([s.x,s.y]);
        if(s.trail.length>22) s.trail.shift();
        if(s.age>s.maxAge) iStars.splice(i,1);
      }

      // Trail fade: normal pace early, then speed up to clear canvas for the dissolve
      const fillA = ms<1100 ? 0.18 : Math.min(0.18+(ms-1100)/700*0.60, 0.78);
      ctx2d.fillStyle=`rgba(3,7,18,${fillA})`; ctx2d.fillRect(0,0,IW,IH);

      // Global dim from 2000 ms → fully invisible by 3400 ms
      const sFade = ms<1000 ? 1 : Math.max(1-(ms-1000)/700, 0);

      if (sFade>0) for (const s of iStars) {
        const a=(1-s.age/s.maxAge)*sFade;
        if(s.trail.length<2) continue;
        // trail
        for (let i=1;i<s.trail.length;i++) {
          const t=i/s.trail.length;
          ctx2d.beginPath();
          ctx2d.strokeStyle=`rgba(190,225,255,${a*t*0.7})`;
          ctx2d.lineWidth=s.w*t*0.85;
          ctx2d.moveTo(s.trail[i-1][0],s.trail[i-1][1]);
          ctx2d.lineTo(s.trail[i][0],s.trail[i][1]);
          ctx2d.stroke();
        }
        // head bloom
        const hg=ctx2d.createRadialGradient(s.x,s.y,0,s.x,s.y,s.w*3.5);
        hg.addColorStop(0,  `rgba(255,255,255,${a*0.95})`);
        hg.addColorStop(0.3,`rgba(200,230,255,${a*0.5})`);
        hg.addColorStop(1,  'rgba(0,0,0,0)');
        ctx2d.fillStyle=hg;
        ctx2d.beginPath(); ctx2d.arc(s.x,s.y,s.w*3.5,0,Math.PI*2); ctx2d.fill();
      }

      // Dissolve intro overlay → hero emerges from darkness
      if (ms>=iP4 && ms<iFE) {
        intro.style.opacity=String(1-(ms-iP4)/(iFE-iP4));
      } else if (ms>=iFE && !iDone) {
        iDone=true; intro.style.display='none';
        cancelAnimationFrame(iRaf2);
      }
    }
    iLoop2();
    const iSkipBtn = document.getElementById('intro-skip-btn') as HTMLElement;
    if (iSkipBtn) setTimeout(()=>{ iSkipBtn.style.opacity='1'; }, 800);
  }

  // ── HERO GEM ─────────────────────────────────────
  // ヒーローセクションが画面外のときrAFを停止してCPU/GPUを節約
  let heroVisible = true;
  new IntersectionObserver(([e]) => { heroVisible = e.isIntersecting; }, { threshold: 0 })
    .observe(document.getElementById('hero-section')!);

  (function initGem() {
    const canvas = document.getElementById('gem-canvas') as HTMLCanvasElement;
    // WebGL非対応確認は一時キャンバスで行う（本番canvasでgetContextするとThree.jsがwebgl2を取得できなくなる）
    const _t = document.createElement('canvas');
    if (!(_t.getContext('webgl2') || _t.getContext('webgl') || _t.getContext('experimental-webgl'))) {
      (document.getElementById('gem-fallback') as HTMLElement).style.display = 'flex';
      canvas.style.display = 'none';
      return;
    }
    const wrapper = canvas.parentElement as HTMLElement;

    const renderer = buildRenderer(canvas);
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    camera.position.set(0, 0.1, 4.8);
    camera.lookAt(0, -0.1, 0);
    buildEnv(renderer, scene);

    scene.add(new THREE.AmbientLight(0xffffff, 0.5));
    const lA = new THREE.PointLight(0x60a5fa, 16, 20);
    lA.position.set(3, 3, 4);
    scene.add(lA);
    const lB = new THREE.PointLight(0xbfdbfe, 8, 15);
    lB.position.set(-3, 2, -2);
    scene.add(lB);
    const lC = new THREE.PointLight(0x2563eb, 7, 18);
    lC.position.set(0, -5, 2);
    scene.add(lC);
    // 高速周回フラッシュ光（輝度パルス）
    const lD = new THREE.PointLight(0x6699ff, 20, 10);
    lD.position.set(2, 1, 3);
    scene.add(lD);
    // 補助アクセント光
    const lE = new THREE.PointLight(0x93c5fd, 9, 16);
    lE.position.set(-1, -3, 3);
    scene.add(lE);

    const gem = new THREE.Mesh(buildDiamond(), buildMaterial());
    gem.rotation.y = Math.PI / 8;
    scene.add(gem);

    // ── モバイル判定（横浮遊 / 縦浮遊の切り替え） ──
    let isMobileGem = window.innerWidth < 1024;

    // ── 浮遊Y範囲を「Sharpen」〜「削り合い」テキスト位置にDOMで合わせる ──
    let gemYMin = -0.25, gemYMax = 0.20;
    function calcGemYBounds() {
      const hl1   = document.querySelector('.hl-1')   as HTMLElement | null;
      const rise2 = document.querySelector('.rise-2') as HTMLElement | null;
      if (!hl1 || !rise2) return;
      const wRect = wrapper.getBoundingClientRect();
      if (wRect.height < 10) return;
      const worldH    = 2 * Math.tan((camera.fov * Math.PI / 180) / 2) * camera.position.z;
      const pxToWorld = worldH / wRect.height;
      const canvasCY  = wRect.top + wRect.height / 2;
      const rawMax = -(hl1.getBoundingClientRect().top      - canvasCY) * pxToWorld;
      const rawMin = -(rise2.getBoundingClientRect().bottom - canvasCY) * pxToWorld;
      // ジェム実寸（クラウン0.30 + パビリオン0.84）でキャンバス端クリップを防ぐ
      const half = worldH / 2;
      gemYMax = Math.min(rawMax, half - 0.30 - 0.15);
      gemYMin = Math.max(rawMin, -(half - 0.84 - 0.15));
    }

    function resize() {
      const w = wrapper.clientWidth;
      const h = wrapper.clientHeight || w * 1.33;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      isMobileGem = window.innerWidth < 1024;
      if (!isMobileGem) calcGemYBounds();
    }
    resize();
    new ResizeObserver(resize).observe(wrapper);

    let mx = 0, my = 0;
    window.addEventListener('mousemove', e => {
      mx =  (e.clientX / window.innerWidth  - 0.5);
      my = -(e.clientY / window.innerHeight - 0.5);
    });

    let t = 0;
    (function loop() {
      requestAnimationFrame(loop);
      if (!heroVisible) return;
      t += 0.008;
      gem.rotation.y += 0.005 + mx * 0.018;
      gem.rotation.x  = 0.30 + my * 0.10 + Math.sin(t * 0.47) * 0.07;
      gem.rotation.z  = Math.sin(t * 0.33) * 0.05;
      if (isMobileGem) {
        // モバイル：横浮遊
        gem.position.x = Math.sin(t * 0.38) * 0.50 + Math.cos(t * 0.22) * 0.20;
        gem.position.y = Math.sin(t * 0.29) * 0.06;
        gem.position.z = Math.sin(t * 0.41) * 0.06 + Math.cos(t * 0.23) * 0.04;
      } else {
        // PC：縦浮遊
        gem.position.x  = Math.sin(t * 0.29) * 0.09 + Math.cos(t * 0.17) * 0.06 - 0.06;
        const yOsc = Math.sin(t * 0.53) * 0.16 + Math.cos(t * 0.37) * 0.10; // ±0.26
        gem.position.y = (gemYMin + gemYMax) / 2 + (yOsc / 0.26) * (gemYMax - gemYMin) / 2;
        gem.position.z  = Math.sin(t * 0.41) * 0.10 + Math.cos(t * 0.23) * 0.07;
      }
      lA.position.x   = Math.cos(t * 0.5) * 4;
      lA.position.z   = Math.sin(t * 0.5) * 4;
      lC.position.x   = Math.sin(t * 0.3) * 3;
      // lD: 高速周回 + 輝度パルス
      lD.position.x   = Math.cos(t * 1.5 + 1) * 3.5;
      lD.position.y   = Math.sin(t * 1.1) * 2;
      lD.position.z   = Math.sin(t * 1.5 + 1) * 3.5;
      lD.intensity    = 16 + Math.sin(t * 3.2) * 10;
      // lE: 緩やかな補助周回
      lE.position.x   = Math.sin(t * 0.6 + 3) * 3;
      lE.position.z   = Math.cos(t * 0.6 + 3) * 2;
      renderer.render(scene, camera);
    })();
  })();

  // ── HERO STARS (ambient background) ──────────────
  (function() {
    const hs = document.getElementById('hero-stars') as HTMLCanvasElement;
    if (!hs) return;
    const hx = hs.getContext('2d')!;
    const hdpr = Math.min(devicePixelRatio, 2);

    function hsResize() {
      hs.width  = hs.clientWidth  * hdpr;
      hs.height = hs.clientHeight * hdpr;
      hx.setTransform(hdpr, 0, 0, hdpr, 0, 0);
    }
    hsResize();
    new ResizeObserver(hsResize).observe(hs);

    interface HStar { x:number;y:number;vx:number;vy:number;age:number;maxAge:number;trail:[number,number][];w:number; }
    const hsl: HStar[] = [];
    const hst0 = performance.now();
    let hsprev = hst0, hsNext = 2500;

    function spawnHS() {
      const HW = hs.clientWidth, HH = hs.clientHeight;
      const inner = Math.random() < 0.35;
      const spd = 180 + Math.random() * 300;
      let x=0,y=0,vx=0,vy=0;
      if (inner) {
        x=HW*(0.18+Math.random()*0.64); y=HH*(0.18+Math.random()*0.64);
        const a=Math.random()*Math.PI*2; vx=Math.cos(a)*spd; vy=Math.sin(a)*spd;
      } else {
        const side=Math.floor(Math.random()*4);
        if (side===0){ x=Math.random()*HW; y=-10; vx=(Math.random()-.5)*spd*0.6; vy=spd*0.9; }
        else if(side===1){ x=HW+10; y=Math.random()*HH; vx=-spd*0.9; vy=(Math.random()-.5)*spd*0.6; }
        else if(side===2){ x=Math.random()*HW; y=HH+10; vx=(Math.random()-.5)*spd*0.6; vy=-spd*0.9; }
        else { x=-10; y=Math.random()*HH; vx=spd*0.9; vy=(Math.random()-.5)*spd*0.6; }
      }
      hsl.push({ x,y,vx,vy,age:0, maxAge:0.4+Math.random()*0.6, trail:[], w:0.5+Math.random()*1.6 });
    }

    (function hLoop() {
      requestAnimationFrame(hLoop);
      if (!heroVisible) return;
      const now=performance.now(), ms=now-hst0, dt=Math.min((now-hsprev)/1000,0.05);
      hsprev=now;
      const HW=hs.clientWidth, HH=hs.clientHeight;

      if (ms>hsNext) {
        spawnHS();
        if (Math.random()<0.28) spawnHS();
        hsNext=ms+2000+Math.random()*3500;
      }

      for (let i=hsl.length-1;i>=0;i--) {
        const s=hsl[i]; s.age+=dt; s.x+=s.vx*dt; s.y+=s.vy*dt;
        s.trail.push([s.x,s.y]); if(s.trail.length>20) s.trail.shift();
        if(s.age>s.maxAge) hsl.splice(i,1);
      }

      hx.clearRect(0,0,HW,HH);

      for (const s of hsl) {
        const a=1-s.age/s.maxAge; if(s.trail.length<2) continue;
        for (let i=1;i<s.trail.length;i++) {
          const t=i/s.trail.length;
          hx.beginPath();
          hx.strokeStyle=`rgba(190,225,255,${a*t*0.55})`;
          hx.lineWidth=s.w*t*0.8;
          hx.moveTo(s.trail[i-1][0],s.trail[i-1][1]);
          hx.lineTo(s.trail[i][0],s.trail[i][1]);
          hx.stroke();
        }
        const g=hx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.w*4);
        g.addColorStop(0,`rgba(255,255,255,${a*0.88})`);
        g.addColorStop(0.4,`rgba(190,225,255,${a*0.35})`);
        g.addColorStop(1,'rgba(0,0,0,0)');
        hx.fillStyle=g; hx.beginPath(); hx.arc(s.x,s.y,s.w*4,0,Math.PI*2); hx.fill();
      }
    })();
  })();

  // bfcache（ブラウザの戻る・進む）から復元されたとき
  // WebGLコンテキストが失われているためリロードして再初期化する
  window.addEventListener('pageshow', (e) => {
    if ((e as PageTransitionEvent).persisted) location.reload();
  });
</script>

