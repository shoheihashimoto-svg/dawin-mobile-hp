<script>
  document.querySelectorAll('.tap-card').forEach(card => {
    card.addEventListener('click', () => {
      const overlay = card.querySelector('.card-overlay');
      const isOpen = !overlay.classList.contains('translate-y-full');
      document.querySelectorAll('.card-overlay').forEach(o => o.classList.add('translate-y-full'));
      document.querySelectorAll('.tap-card > div:first-child').forEach(f => {
        (f as HTMLElement).style.opacity = '';
        (f as HTMLElement).style.transform = '';
      });
      if (!isOpen) {
        overlay.classList.remove('translate-y-full');
        const front = card.querySelector(':scope > div:first-child') as HTMLElement;
        if (front) { front.style.opacity = '0'; front.style.transform = 'scale(0.95)'; }
      }
    });
  });

  // ─ ①+② 星スパークル ─
  (function() {
    const syms   = ['✦', '✧', '✦', '✧', '✦'];
    const colors = ['#a5b4fc', '#c4b5fd', '#93c5fd', '#ddd6fe', '#818cf8'];

    function spawnStar(card: Element) {
      const overlay = card.querySelector('.card-overlay');
      if (overlay && !overlay.classList.contains('translate-y-full')) return;
      const el = document.createElement('span');
      const dur = (0.85 + Math.random() * 0.75).toFixed(2);
      const size = (card as HTMLElement).clientWidth || 180;
      const pad = size * 0.13;
      el.textContent = syms[Math.floor(Math.random() * syms.length)];
      el.style.cssText = [
        'position:absolute',
        'pointer-events:none',
        'opacity:0',
        'z-index:1',
        'transform-origin:center',
        'line-height:1',
        `left:${(pad + Math.random() * (size - pad * 2)).toFixed(0)}px`,
        `top:${(pad + Math.random() * (size - pad * 2)).toFixed(0)}px`,
        `font-size:${(8 + Math.random() * 11).toFixed(0)}px`,
        `color:${colors[Math.floor(Math.random() * colors.length)]}`,
        `animation:hexCardStarPop ${dur}s ease-out forwards`,
      ].join(';');
      card.appendChild(el);
      setTimeout(() => el.remove(), parseFloat(dur) * 1000 + 80);
    }

    document.querySelectorAll('.hex-card').forEach((card, idx) => {
      const delay = idx * 350;
      [delay + 200, delay + 520, delay + 840].forEach(t => setTimeout(() => spawnStar(card), t));
      function loop() {
        spawnStar(card);
        if (Math.random() < 0.38) setTimeout(() => spawnStar(card), 160 + Math.random() * 130);
        setTimeout(loop, 400 + Math.random() * 360);
      }
      setTimeout(loop, delay + 1050);
    });
  })();
</script>

