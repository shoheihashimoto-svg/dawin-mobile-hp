---
import Layout from '../layouts/Layout.astro';
---
<Layout title="HOME">

<style>
  /* ================= INTRO ================= */
  #intro { clip-path: polygon(50% -130%, 230% 50%, 50% 230%, -130% 50%); }
  #intro.exit { animation: irisOut 1s cubic-bezier(0.76, 0, 0.24, 1) forwards; }
  @keyframes irisOut { to { clip-path: polygon(50% 50%, 50% 50%, 50% 50%, 50% 50%); } }
  #intro.exit .intro-stage { animation: stageOut 1s cubic-bezier(0.76, 0, 0.24, 1) forwards; }
  @keyframes stageOut { to { transform: scale(0.9); opacity: 0.4; } }

  .i-beam { transform-origin: center; animation: beamIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both; }
  @keyframes beamIn {
    0%   { transform: scaleX(0); opacity: 0; }
    40%  { transform: scaleX(1); opacity: 1; }
    100% { transform: scaleX(1); opacity: 0; }
  }

  .i-shard-l { animation: shardInL 0.8s cubic-bezier(0.55, 0, 0.85, 0.4) 0.15s both, shardVanish 0.3s ease-out 0.92s both; }
  .i-shard-r { animation: shardInR 0.8s cubic-bezier(0.55, 0, 0.85, 0.4) 0.15s both, shardVanish 0.3s ease-out 0.92s both; }
  @keyframes shardInL {
    0%   { transform: translate(calc(-50% - 46vw), -50%) rotate(-80deg); opacity: 0; }
    18%  { opacity: 1; }
    100% { transform: translate(calc(-50% - 26px), -50%) rotate(0deg); opacity: 1; }
  }
  @keyframes shardInR {
    0%   { transform: translate(calc(-50% + 46vw), -50%) rotate(80deg); opacity: 0; }
    18%  { opacity: 1; }
    100% { transform: translate(calc(-50% + 26px), -50%) rotate(0deg); opacity: 1; }
  }
  @keyframes shardVanish {
    0%   { opacity: 1; filter: brightness(1); }
    50%  { opacity: 1; filter: brightness(3.5); }
    100% { opacity: 0; filter: brightness(5); }
  }

  .i-flash { animation: flashBurst 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.9s both; }
  @keyframes flashBurst {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.15); }
    18%  { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(2.8); }
  }
  .i-ring   { animation: ringOut 1s cubic-bezier(0.16, 1, 0.3, 1) 0.95s both; }
  .i-ring-2 { animation: ringOut 1.25s cubic-bezier(0.16, 1, 0.3, 1) 1.1s both; }
  @keyframes ringOut {
    0%   { opacity: 0.9; transform: translate(-50%, -50%) scale(0.12); }
    100% { opacity: 0;   transform: translate(-50%, -50%) scale(3.6); }
  }
  .i-ray-h { animation: rayH 1.3s cubic-bezier(0.16, 1, 0.3, 1) 1.02s both; }
  @keyframes rayH {
    0%   { transform: translate(-50%, -50%) scaleX(0); opacity: 0; }
    25%  { opacity: 0.9; }
    100% { transform: translate(-50%, -50%) scaleX(1); opacity: 0; }
  }
  .i-ray-v { animation: rayV 1.3s cubic-bezier(0.16, 1, 0.3, 1) 1.08s both; }
  @keyframes rayV {
    0%   { transform: translate(-50%, -50%) rotate(90deg) scaleX(0); opacity: 0; }
    25%  { opacity: 0.7; }
    100% { transform: translate(-50%, -50%) rotate(90deg) scaleX(1); opacity: 0; }
  }

  .i-gem { animation: gemIn 1s cubic-bezier(0.22, 1.2, 0.36, 1) 1s both; }
  @keyframes gemIn {
    0%   { opacity: 0; transform: scale(0.2) rotate(-140deg); }
    45%  { opacity: 1; }
    70%  { transform: scale(1.07) rotate(7deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  .i-line-1 .i-line-in { animation: lineUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 1.8s both; }
  .i-line-2 .i-line-in { animation: lineUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 2.05s both; }
  @keyframes lineUp { from { transform: translateY(115%); } to { transform: translateY(0); } }
  .i-jp { animation: jpIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) 2.45s both; }
  @keyframes jpIn {
    from { opacity: 0; letter-spacing: 1.1em; }
    to   { opacity: 1; letter-spacing: 0.5em; }
  }

  /* ================= HERO ================= */
  .rise { animation: riseUp 1s cubic-bezier(0.22, 1, 0.36, 1) both; }
  @keyframes riseUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .rise-1 { animation-delay: 0.15s; }
  .rise-2 { animation-delay: 0.7s; }
  .rise-3 { animation-delay: 0.85s; }
  .rise-4 { animation-delay: 1s; }

  .hl-1 { animation: lineUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both; }
  .hl-2 { animation: lineUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both; }
  .hl-3 { animation: lineUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.55s both; }

  .fade-in { animation: fadeIn 1.2s ease 1.4s both; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .shine-text {
    background: linear-gradient(105deg, #3b82f6 0%, #93c5fd 25%, #f0f9ff 50%, #93c5fd 75%, #3b82f6 100%);
    background-size: 220% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: sheen 5.5s linear infinite;
  }
  @keyframes sheen { to { background-position: -220% center; } }

  .gem-wrap {
    animation: gemEnter 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.45s both,
               gemFloat 9s ease-in-out 2.4s infinite;
  }
  @keyframes gemEnter {
    from { opacity: 0; transform: translateY(46px) scale(0.88); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes gemFloat {
    0%, 100% { transform: translateY(0) rotate(0.5deg); }
    50%      { transform: translateY(-16px) rotate(-0.5deg); }
  }

  .gem-glow { animation: glowPulse 6s ease-in-out infinite; }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.25; transform: translateY(-50%) scale(0.9); }
    50%      { opacity: 0.55; transform: translateY(-50%) scale(1.08); }
  }

  .shaft { animation: shaftSway 16s ease-in-out infinite alternate; }
  @keyframes shaftSway {
    from { transform: rotate(20deg) translateX(-40px); opacity: 0.5; }
    to   { transform: rotate(25deg) translateX(40px);  opacity: 1; }
  }

  .spark { position: absolute; border-radius: 9999px; background: #bfdbfe; animation: twinkle 5.5s ease-in-out infinite; }
  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: translateY(0) scale(0.5); }
    50%      { opacity: 0.7; transform: translateY(-20px) scale(1); }
  }

  .spin-slow { animation: spinSlow 90s linear infinite; }
  @keyframes spinSlow { to { transform: rotate(360deg); } }

  .scroll-dot { animation: scrollDot 2.4s cubic-bezier(0.76, 0, 0.24, 1) infinite; }
  @keyframes scrollDot {
    0%   { transform: translateY(0); opacity: 0; }
    15%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(44px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    #intro { display: none !important; }
    * { animation-duration: 0.001s !important; animation-delay: 0s !important; animation-iteration-count: 1 !important; }
  }
</style>

<!-- ===== INTRO OVERLAY ===== -->
<div id="intro" class="fixed inset-0 z-[200] bg-gray-950 overflow-hidden select-none pointer-events-none" aria-hidden="true">
  <div class="intro-stage absolute inset-0 flex flex-col items-center justify-center">

    <!-- 衝突ステージ -->
    <div class="relative w-full h-60 md:h-72 flex items-center justify-center mb-8">
      <!-- 光の軌道線 -->
      <div class="i-beam absolute inset-x-0 top-1/2 h-px" style="background:linear-gradient(90deg, transparent, rgba(147,197,253,0.7), transparent);"></div>

      <!-- 原石（左） -->
      <div class="i-shard-l absolute left-1/2 top-1/2">
        <svg viewBox="0 0 120 140" class="w-16 h-20 md:w-20 md:h-24">
          <defs>
            <linearGradient id="i-sh-a" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1e3a8a"/><stop offset="1" stop-color="#0f172a"/></linearGradient>
            <linearGradient id="i-sh-b" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#3b82f6"/><stop offset="1" stop-color="#1e40af"/></linearGradient>
          </defs>
          <polygon points="14,74 42,10 104,26 110,88 58,132" fill="url(#i-sh-a)"/>
          <polygon points="42,10 104,26 66,70" fill="url(#i-sh-b)" opacity="0.9"/>
          <polygon points="14,74 66,70 58,132" fill="#172554"/>
          <polygon points="66,70 110,88 58,132" fill="url(#i-sh-b)" opacity="0.55"/>
          <polygon points="14,74 42,10 66,70" fill="#1d4ed8" opacity="0.7"/>
          <polygon points="14,74 42,10 104,26 110,88 58,132" fill="none" stroke="#93c5fd" stroke-width="1" opacity="0.5"/>
        </svg>
      </div>
      <!-- 原石（右） -->
      <div class="i-shard-r absolute left-1/2 top-1/2">
        <svg viewBox="0 0 120 140" class="w-16 h-20 md:w-20 md:h-24 -scale-x-100">
          <polygon points="14,74 42,10 104,26 110,88 58,132" fill="url(#i-sh-a)"/>
          <polygon points="42,10 104,26 66,70" fill="url(#i-sh-b)" opacity="0.9"/>
          <polygon points="14,74 66,70 58,132" fill="#172554"/>
          <polygon points="66,70 110,88 58,132" fill="url(#i-sh-b)" opacity="0.55"/>
          <polygon points="14,74 42,10 66,70" fill="#1d4ed8" opacity="0.7"/>
          <polygon points="14,74 42,10 104,26 110,88 58,132" fill="none" stroke="#93c5fd" stroke-width="1" opacity="0.5"/>
        </svg>
      </div>

      <!-- 衝突の閃光 -->
      <div class="i-flash absolute left-1/2 top-1/2 w-72 h-72 rounded-full" style="background:radial-gradient(circle, rgba(240,249,255,0.95), rgba(96,165,250,0.4) 40%, transparent 70%);"></div>
      <div class="i-ring absolute left-1/2 top-1/2 w-40 h-40 rounded-full border border-blue-200/70"></div>
      <div class="i-ring-2 absolute left-1/2 top-1/2 w-40 h-40 rounded-full border border-blue-400/40"></div>
      <div class="i-ray-h absolute left-1/2 top-1/2 w-[110vw] h-px" style="background:linear-gradient(90deg, transparent, rgba(224,242,254,0.9), transparent);"></div>
      <div class="i-ray-v absolute left-1/2 top-1/2 w-[70vh] h-px" style="background:linear-gradient(90deg, transparent, rgba(224,242,254,0.7), transparent);"></div>

      <!-- 誕生するダイヤ -->
      <div class="i-gem relative">
        <svg viewBox="0 0 400 480" class="w-36 h-44 md:w-44 md:h-52 drop-shadow-[0_0_40px_rgba(59,130,246,0.45)]">
          <defs>
            <linearGradient id="i-tbl" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#f0f9ff"/><stop offset="1" stop-color="#93c5fd"/></linearGradient>
            <linearGradient id="i-star-l" x1="1" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#93c5fd"/><stop offset="1" stop-color="#2563eb"/></linearGradient>
            <linearGradient id="i-star-r" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#e0f2fe"/><stop offset="1" stop-color="#60a5fa"/></linearGradient>
            <linearGradient id="i-crown-c" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#60a5fa"/><stop offset="1" stop-color="#1d4ed8"/></linearGradient>
            <linearGradient id="i-crown-cl" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1d4ed8"/><stop offset="1" stop-color="#1e3a8a"/></linearGradient>
            <linearGradient id="i-crown-cr" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#3b82f6"/><stop offset="1" stop-color="#1d4ed8"/></linearGradient>
            <linearGradient id="i-corner-l" x1="1" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1e40af"/><stop offset="1" stop-color="#172554"/></linearGradient>
            <linearGradient id="i-corner-r" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#60a5fa"/><stop offset="1" stop-color="#1e40af"/></linearGradient>
            <linearGradient id="i-girdle" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#1e3a8a"/><stop offset="0.5" stop-color="#bfdbfe"/><stop offset="1" stop-color="#1e40af"/></linearGradient>
            <linearGradient id="i-pav-ol" x1="1" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1e3a8a"/><stop offset="1" stop-color="#0f172a"/></linearGradient>
            <linearGradient id="i-pav-l" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1e40af"/><stop offset="1" stop-color="#172554"/></linearGradient>
            <linearGradient id="i-pav-cl" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#2563eb"/><stop offset="1" stop-color="#1e3a8a"/></linearGradient>
            <linearGradient id="i-pav-cr" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#60a5fa"/><stop offset="1" stop-color="#1d4ed8"/></linearGradient>
            <linearGradient id="i-pav-r" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#3b82f6"/><stop offset="1" stop-color="#172554"/></linearGradient>
            <linearGradient id="i-pav-or" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1e3a8a"/><stop offset="1" stop-color="#0f172a"/></linearGradient>
            <linearGradient id="i-shimmer" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="white" stop-opacity="0"/><stop offset="0.5" stop-color="white" stop-opacity="0.4"/><stop offset="1" stop-color="white" stop-opacity="0"/></linearGradient>
            <filter id="i-f" x="-30%" y="-20%" width="160%" height="140%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="b"/>
              <feColorMatrix in="b" type="matrix" values="0 0 0 0 0.15 0 0 0 0 0.35 0 0 0 0 1 0 0 0 1.6 0" result="cb"/>
              <feMerge><feMergeNode in="cb"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <clipPath id="i-clip"><polygon points="128,16 272,16 394,170 388,184 200,472 12,184 6,170"/></clipPath>
          </defs>
          <g clip-path="url(#i-clip)" filter="url(#i-f)">
            <polygon points="128,16 272,16 235,88 165,88" fill="url(#i-tbl)"/>
            <polygon points="128,16 165,88 102,170" fill="url(#i-star-l)"/>
            <polygon points="272,16 298,170 235,88" fill="url(#i-star-r)"/>
            <polygon points="165,88 235,88 200,170" fill="url(#i-crown-c)"/>
            <polygon points="165,88 200,170 102,170" fill="url(#i-crown-cl)"/>
            <polygon points="235,88 298,170 200,170" fill="url(#i-crown-cr)"/>
            <polygon points="6,170 128,16 102,170" fill="url(#i-corner-l)"/>
            <polygon points="394,170 272,16 298,170" fill="url(#i-corner-r)"/>
            <polygon points="6,170 394,170 388,184 12,184" fill="url(#i-girdle)" opacity="0.9"/>
            <polygon points="12,184 60,184 200,472" fill="url(#i-pav-ol)"/>
            <polygon points="60,184 104,184 200,472" fill="url(#i-pav-l)"/>
            <polygon points="104,184 200,184 200,472" fill="url(#i-pav-cl)"/>
            <polygon points="200,184 296,184 200,472" fill="url(#i-pav-cr)"/>
            <polygon points="296,184 340,184 200,472" fill="url(#i-pav-r)"/>
            <polygon points="340,184 388,184 200,472" fill="url(#i-pav-or)"/>
            <line x1="6" y1="170" x2="394" y2="170" stroke="#93c5fd" stroke-width="0.8" opacity="0.5"/>
            <line x1="12" y1="184" x2="388" y2="184" stroke="#93c5fd" stroke-width="0.6" opacity="0.35"/>
            <line x1="200" y1="184" x2="200" y2="472" stroke="#60a5fa" stroke-width="0.5" opacity="0.3"/>
          </g>
          <g clip-path="url(#i-clip)">
            <rect x="0" y="0" width="150" height="480" fill="url(#i-shimmer)" transform="translate(-420 0)">
              <animateTransform attributeName="transform" type="translate" values="-420 0;820 0" dur="1.3s" begin="2s" repeatCount="1" fill="freeze"/>
            </rect>
          </g>
          <polygon points="128,16 272,16 394,170 388,184 200,472 12,184 6,170" fill="none" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
          <line x1="128" y1="16" x2="272" y2="16" stroke="#e0f2fe" stroke-width="2.5" opacity="0.9"/>
        </svg>
      </div>
    </div>

    <!-- コピー -->
    <div class="i-line-1 overflow-hidden px-4">
      <p class="i-line-in text-2xl md:text-4xl font-black uppercase tracking-[0.18em] text-white text-center">Sharpen each other.</p>
    </div>
    <div class="i-line-2 overflow-hidden px-4 mt-2 pb-1">
      <p class="i-line-in shine-text text-2xl md:text-4xl font-black uppercase tracking-[0.18em] text-center">Shine together.</p>
    </div>
    <p class="i-jp mt-7 text-xs md:text-sm font-semibold text-blue-200/80 text-center">削り合い、輝いていけ。</p>

  </div>
</div>

<!-- ===== HERO ===== -->
<section class="relative min-h-screen flex items-center text-white overflow-hidden bg-gray-950">

  <!-- 背景レイヤー -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- ダイヤ背後の光彩 -->
    <div class="gem-glow absolute right-[4%] top-1/2 w-[640px] h-[640px] rounded-full blur-[150px]" style="background:radial-gradient(circle, rgba(37,99,235,0.3), rgba(30,58,138,0.12) 55%, transparent 75%);"></div>
    <div class="absolute -left-24 top-[16%] w-96 h-96 bg-indigo-700/10 rounded-full blur-[110px]"></div>
    <!-- ライトシャフト -->
    <div class="shaft absolute -top-[30%] left-[16%] w-[26rem] h-[130vh] blur-3xl" style="background:linear-gradient(to bottom, rgba(96,165,250,0.1), rgba(96,165,250,0.02) 55%, transparent);"></div>
    <div class="shaft absolute -top-[30%] left-[46%] w-[18rem] h-[130vh] blur-3xl" style="background:linear-gradient(to bottom, rgba(147,197,253,0.07), transparent 60%); animation-delay:-8s;"></div>
    <!-- グリッド -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(rgba(255,255,255,.6) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.6) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 80% 70% at 50% 45%, black, transparent);-webkit-mask-image:radial-gradient(ellipse 80% 70% at 50% 45%, black, transparent);"></div>
    <!-- 巨大ワイヤーフレーム・ダイヤ -->
    <svg viewBox="0 0 400 480" class="spin-slow absolute -left-52 -bottom-72 w-[42rem] h-[50rem] opacity-[0.05]">
      <polygon points="112,10 288,10 400,175 200,470 0,175" fill="none" stroke="#60a5fa" stroke-width="1"/>
      <line x1="0" y1="175" x2="400" y2="175" stroke="#60a5fa" stroke-width="0.6"/>
      <line x1="112" y1="10" x2="200" y2="470" stroke="#60a5fa" stroke-width="0.4"/>
      <line x1="288" y1="10" x2="200" y2="470" stroke="#60a5fa" stroke-width="0.4"/>
    </svg>
    <!-- 微粒子 -->
    <span class="spark w-1 h-1" style="left:12%; top:32%;"></span>
    <span class="spark w-1.5 h-1.5" style="left:26%; top:68%; animation-delay:1.4s;"></span>
    <span class="spark w-1 h-1" style="left:55%; top:20%; animation-delay:2.8s;"></span>
    <span class="spark w-1 h-1" style="left:70%; top:78%; animation-delay:2s;"></span>
    <span class="spark w-1.5 h-1.5" style="left:88%; top:30%; animation-delay:3.6s;"></span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full pt-28 pb-28 md:py-28">
    <div class="grid lg:grid-cols-12 gap-14 lg:gap-8 items-center">

      <!-- 左：コピー -->
      <div class="order-2 lg:order-1 lg:col-span-7">
        <div class="rise rise-1 flex items-center gap-4 mb-8">
          <span class="w-12 h-px bg-gradient-to-r from-blue-400 to-transparent"></span>
          <p class="text-blue-400/80 font-bold tracking-[0.4em] text-xs uppercase">Dawin Mobile Division</p>
        </div>
        <h1 class="font-black tracking-tight mb-8">
          <span class="block overflow-hidden pb-[0.14em] -mb-[0.14em]">
            <span class="hl-1 block leading-none text-white text-[clamp(3rem,8vw,6.5rem)]">Sharpen</span>
          </span>
          <span class="block overflow-hidden pb-[0.14em] -mb-[0.14em]">
            <span class="hl-2 block leading-none text-white text-[clamp(3rem,8vw,6.5rem)]">each other.</span>
          </span>
          <span class="block overflow-hidden pb-[0.16em] -mb-[0.1em] mt-1">
            <span class="hl-3 shine-text block leading-none text-[clamp(3rem,8vw,6.5rem)]">Shine together.</span>
          </span>
        </h1>
        <p class="rise rise-2 text-blue-200/90 font-semibold text-base md:text-lg tracking-[0.45em] mb-7">削り合い、輝いていけ。</p>
        <p class="rise rise-3 text-gray-400 text-base leading-relaxed mb-11 max-w-md">
          挑戦を楽しみ、仲間を大切にする人たちが集まるチーム。<br />あなたの「成長したい」を、ここで形にしませんか。
        </p>
        <div class="rise rise-4 flex flex-col sm:flex-row gap-4">
          <a href="/recruit"
            class="group relative overflow-hidden rounded-full bg-white px-10 py-4 text-center text-lg font-black text-blue-950 transition-all duration-500 hover:-translate-y-0.5 hover:shadow-[0_0_50px_rgba(96,165,250,0.55)]">
