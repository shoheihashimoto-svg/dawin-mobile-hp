---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const staffData = {
    inataba: {
      name: '犬束 誠',
      role: 'エリアマネージャー（九州）',
      color: 'from-indigo-900 to-indigo-700',
      photo: '/inataba.jpg',
      photoPosition: '38% 28%',
      mainPhoto: '/inataba_main.jpg',
      mainCaption: '休日は子供と一緒に',
      quote: 'チームがあるから、もっと頑張れる。',
      qa: [
        {
          q: 'ダウインに入ったきっかけは？',
          a: '部長の橋本とは20代の中盤から付き合いがあって、当時は自分が携帯代理店側にいたんですよね。そのころからずっと関わりがあって、「一緒にやろう」という話になりました。もともと業界のことはわかっていたので、仕事のイメージはできていましたね。',
        },
        {
          q: '仕事でいちばんやりがいを感じるのは？',
          a: 'チームが機能しているときですかね。九州のチームをまとめているんですが、メンバーが自分で考えて動けるようになってきたときに、「あ、いいチームになってきたな」って感じます。そこが一番うれしい。',
        },
        {
          q: 'プライベートでは？',
          a: '子供が4人いるんですよ（笑）。昔は仕事がかなりハードで、子供との時間がなかなか取れなかったんですが、今は休みの日はできるだけ一緒にいるようにしています。',
        },
        {
          q: 'バスケのコーチもしてると聞きました',
          a: 'もともと自分がバスケをやっていて、今は子供2人もバスケットをやっているんです。平日はコーチもやっていて、練習に顔を出したりしていますね。仕事もバスケも、チームで動くのが好きなんだと思います（笑）。',
        },
      ],
    },
    oba: {
      name: '大塲 塁',
      role: 'スタッフ',
      color: 'from-cyan-900 to-blue-800',
      photo: '/oba.jpg',
      photoPosition: '50% 54%',
      mainPhoto: '/oba-off.jpg',
      mainCaption: 'オフの日もフルスロットル',
      quote: '自分を変えたい、挑戦したいと思っているなら、ぜひここへ。',
      qa: [
        {
          q: 'ダウインに入ったきっかけは？',
          a: 'もともと仙台でホテルマンをやっていて、ひょんな縁からダウインを知って応募したのがきっかけです。友人もほぼいない状態で、ほぼ身一つで東京に出てきました。',
        },
        {
          q: '最初、仕事の印象はどうでしたか？',
          a: 'ホテルの仕事と違って、毎日現場が変わるのがすごく刺激的だなって思いました。最初は「1、2週間お試しで働いてみて、合うようならやろう」くらいの気持ちで始めたんですよね。',
        },
        {
          q: '今も続けている理由は？',
          a: '1、2週間働いてみたら「もっとチャレンジしたい」って思えたから。それがそのまま今につながっています。自分を変えたいと思っている人には、絶対に合う環境だと思います。',
        },
      ],
    },
  };

  return Object.keys(staffData).map((id) => ({ params: { id }, props: { staff: staffData[id] } }));
}

const { staff } = Astro.props;
---
<Layout title={`${staff.name} インタビュー`}>


<!-- Hero -->
<section class="hero-bg relative py-28 px-6 text-white overflow-hidden">
  <div class="absolute inset-0 opacity-5"
    style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <a href="/interview" class="text-blue-300 text-xs font-bold tracking-widest uppercase hover:text-white transition-colors">← INTERVIEW 一覧に戻る</a>
    <div class="mt-6 flex items-center gap-5">
      {staff.photo ? (
        <img src={staff.photo} alt={staff.name}
          class="w-20 h-20 rounded-full object-cover flex-shrink-0"
          style={`object-position: ${staff.photoPosition || '50% 30%'}`} />
      ) : (
        <div class={`w-20 h-20 bg-gradient-to-br ${staff.color} rounded-full flex items-center justify-center text-3xl font-black flex-shrink-0`}>
          {staff.name.charAt(0)}
        </div>
      )}
      <div>
        <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">スタッフインタビュー</span>
        <h1 class="text-3xl md:text-4xl font-black mt-2">{staff.name}</h1>
        <p class="text-blue-200 text-sm mt-1">{staff.role}</p>
      </div>
    </div>
  </div>
</section>

<!-- メイン写真（mainPhoto必須。decisions.md参照） -->
{staff.mainPhoto && (
  <div class="bg-white py-8 px-6">
    <div class="max-w-3xl mx-auto">
      <img src={staff.mainPhoto} alt={staff.name} class="w-full h-auto rounded-2xl block" />
      {staff.mainCaption && (
        <p class="text-center text-sm text-gray-400 mt-3">{staff.mainCaption}</p>
      )}
    </div>
  </div>
)}

<!-- インタビュー本文 -->
<article class="bg-white py-16 px-6">
  <div class="max-w-3xl mx-auto space-y-12">

    {staff.qa.map((item, i) => (
      <div class={i % 2 === 0 ? 'bg-blue-50 rounded-2xl p-8' : ''}>
        <p class="text-blue-600 font-bold text-xs tracking-widest uppercase mb-3">Q{i + 1}</p>
        <p class="text-xl font-black text-gray-900 mb-4">{item.q}</p>
        <p class="text-gray-700 leading-relaxed">{item.a}</p>
      </div>
    ))}

    <!-- 一言メッセージ -->
    <div class="border-l-4 border-blue-600 pl-6 py-2">
      <p class="text-2xl font-black text-gray-900 leading-relaxed">
        「<span class="text-blue-600">{staff.quote}</span>」
      </p>
      <p class="text-gray-500 text-sm mt-3">{staff.name} / {staff.role}</p>
    </div>

    <div class="pt-4 flex flex-col sm:flex-row gap-4">
      <a href="/interview" class="inline-block border-2 border-blue-600 text-blue-600 font-bold px-8 py-3 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 text-center">
        ← インタビュー一覧
      </a>
      <a href="/recruit" class="inline-block bg-blue-600 text-white font-black px-8 py-3 rounded-full hover:bg-blue-700 transition-all duration-300 text-center">
        採用エントリーはこちら →
      </a>
    </div>
  </div>
</article>

</Layout>
