---
import Layout from '../layouts/Layout.astro';

const members = [
  {
    id: 'hashimoto',
    name: '橋本 章平',
    kana: 'Shohei Hashimoto',
    role: 'モバイル事業部 部長',
    year: 'Manager',
    quote: '自ら掴んだチャンスが、自分を変える。',
    color: 'from-blue-900 to-blue-700',
    photo: '/hashimoto.jpg',
  },
  {
    id: 'inataba',
    name: '犬束 誠',
    kana: '',
    role: 'エリアマネージャー（九州）',
    year: 'Area Manager',
    quote: 'チームがあるから、もっと頑張れる。',
    color: 'from-indigo-900 to-indigo-700',
  },
  {
    id: 'kihara',
    name: '木原 裕樹',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: 'モバイルを辞めるつもりだったのに、ここに来たら、また好きになれた。',
    color: 'from-blue-900 to-cyan-700',
    photo: '/kihara.jpg',
    photoPos: '50% 20%',
  },
  {
    id: 'nakamura',
    name: '中村 翔',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: 'いつの間にか、ここが自分の場所になってた。アルバイトから正社員へ、最古参スタッフが語る。',
    color: 'from-slate-800 to-blue-800',
    photo: '/nakamura.jpg',
    photoPos: '50% 12%',
  },
  {
    id: 'takahashi',
    name: '高橋 里佳',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: 'ここの空気感が、ずっと続けられる理由。',
    color: 'from-blue-800 to-indigo-900',
  },
  {
    id: 'mori',
    name: '森 佳奈',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: '一緒に仕事もプライベートも充実させよう！',
    color: 'from-violet-900 to-purple-800',
    photo: '/mori.jpg',
    photoPos: '50% 30%',
  },
  {
    id: 'oba',
    name: '大塲 塁',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: '自分を変えたい、挑戦したいと思っているなら、ぜひここへ。',
    color: 'from-cyan-900 to-blue-800',
    photo: '/oba.jpg',
    photoPos: '50% 54%',
  },
  {
    id: 'takata',
    name: '髙田 亜里沙',
    kana: '',
    role: 'スタッフ',
    year: 'Staff',
    quote: 'とりあえず、やってみよう！ほとんどの人が未経験からのスタートです。',
    color: 'from-indigo-800 to-blue-900',
    photo: '/takata.jpg',
    photoPos: '50% 35%',
  },
];
---
<Layout title="INTERVIEW">


<!-- Hero -->
<section class="hero-bg relative py-32 px-6 text-white text-center overflow-hidden">
  <div class="absolute inset-0 opacity-5"
    style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <p class="text-blue-300 font-bold tracking-[0.3em] text-xs uppercase mb-6">Interview</p>
    <h1 class="text-4xl md:text-6xl font-black mb-6">社員インタビュー</h1>
    <p class="text-blue-100/80 text-base md:text-lg">ここで働く人たちの、<br class="sm:hidden" />リアルな声を届けます。</p>
  </div>
</section>

<!-- インタビュー一覧 -->
<section class="py-20 px-6 bg-gray-950">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {members.map((m) => (
        <a href={`/interview/${m.id}`} class={`group relative bg-gradient-to-br ${m.color} rounded-2xl overflow-hidden block`}>
          <!-- 写真エリア -->
          <div class="h-48 relative overflow-hidden">
            {m.photo ? (
              <img src={m.photo} alt={m.name} class="absolute inset-0 w-full h-full object-cover" style={`object-position: ${m.photoPos ?? '50% 30%'};`} />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-24 h-24 rounded-full bg-white/10 flex items-center justify-center">
                  <span class="text-4xl text-white/50 font-black">{m.name.charAt(0)}</span>
                </div>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
          <!-- 情報 -->
          <div class="p-6 text-white">
            <p class="text-blue-300 text-xs font-bold tracking-widest uppercase mb-1">{m.year}</p>
            <h3 class="text-xl font-black mb-1">{m.name}</h3>
            <p class="text-gray-300 text-xs mb-4">{m.role}</p>
            <p class="text-sm text-gray-200 leading-relaxed border-l-2 border-blue-400 pl-3 italic">
              「{m.quote}」
            </p>
          </div>
          <!-- ホバーオーバーレイ -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/20">
            <span class="bg-white text-blue-600 text-xs font-bold px-4 py-2 rounded-full">インタビューを読む →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="text-center text-gray-600 text-sm mt-12">※ 順次インタビュー記事を公開予定です。</p>
  </div>
</section>

<!-- CTA -->
<section class="py-20 px-6 bg-blue-600 text-white text-center">
  <h2 class="text-2xl md:text-3xl font-black mb-4">仲間の声を聞いて、<br class="sm:hidden" />気になりましたか？</h2>
  <p class="text-blue-100 mb-8">未経験・第二新卒も大歓迎。一歩踏み出してみてください。</p>
  <a href="/recruit" class="inline-block bg-white text-blue-600 font-black px-10 py-4 rounded-full hover:bg-blue-50 transition-all duration-300 hover:shadow-xl">
    エントリーしてみる →
  </a>
</section>

</Layout>
