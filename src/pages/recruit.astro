---
import Layout from '../layouts/Layout.astro';
---
<Layout title="RECRUIT">
<style>
  .who-card {
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
  }
  .who-card-wrap {
    animation: whoAmbient 6s ease-in-out infinite;
  }
  @keyframes whoAmbient {
    0%, 100% { filter: drop-shadow(0 0  0px rgba(59,130,246,0.0)); }
    50%       { filter: drop-shadow(0 0 16px rgba(96,165,250,0.38)); }
  }
  .who-shine {
    position: absolute;
    inset: -20px;
    background: linear-gradient(108deg, transparent 35%, rgba(255,255,255,0) 44%, rgba(255,255,255,0.38) 50%, rgba(255,255,255,0) 56%, transparent 65%);
    transform: translateX(-130%);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
  .who-shine.shine-active {
    animation: whoShine 3.5s ease-in-out forwards;
  }
  @keyframes whoShine {
    0%   { transform: translateX(-130%); opacity: 0; }
    10%  { opacity: 1; }
    90%  { transform: translateX(130%);  opacity: 1; }
    100% { transform: translateX(130%);  opacity: 0; }
  }
  .who-label {
    transition: color 0.4s, text-shadow 0.4s;
  }
  .who-label.glowing {
    animation: whoLabelPulse 2.5s ease-in-out forwards;
  }
  @keyframes whoLabelPulse {
    0%   { color: #60a5fa; text-shadow: none; }
    25%  { color: #e0f2fe; text-shadow: 0 0 6px rgba(147,197,253,1), 0 0 18px rgba(96,165,250,0.8), 0 0 36px rgba(59,130,246,0.5); }
    65%  { color: #e0f2fe; text-shadow: 0 0 6px rgba(147,197,253,1), 0 0 18px rgba(96,165,250,0.8), 0 0 36px rgba(59,130,246,0.5); }
    100% { color: #60a5fa; text-shadow: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .who-card-wrap { animation: none; }
    .who-shine { animation: none; opacity: 0; }
    .who-label.glowing { animation: none; }
  }
</style>


<!-- Hero -->
<section class="hero-bg relative py-16 px-6 text-white text-center overflow-hidden">
  <div class="absolute inset-0 opacity-5"
    style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <p class="text-blue-300 font-bold tracking-[0.3em] text-xs uppercase mb-6">Recruit</p>
    <h1 class="text-4xl md:text-6xl font-black mb-6">採用情報</h1>
    <p class="text-blue-100/80 text-base md:text-lg">自ら掴んだチャンスが、<br class="sm:hidden" />自分を変える。<br />あなたのチャレンジを<br class="sm:hidden" />待っています。</p>
  </div>
</section>

<!-- 求める人物像 -->
<section class="py-24 px-6 bg-gray-950 text-white">
  <div class="max-w-5xl mx-auto">
    <p class="text-blue-400 font-bold text-xs tracking-widest uppercase mb-4 text-center">Who We Want</p>
    <h2 class="text-4xl md:text-5xl font-black text-center mb-4">こんな人と<br class="md:hidden" />働きたい。</h2>
    <p class="text-gray-500 text-center text-sm mb-16">業界・職種未経験でも大歓迎です。</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-8">
      {[
        { keyword: '自分を\n変えたい', sub: 'CHANGE' },
        { keyword: '諦めない', sub: 'NEVER GIVE UP' },
        { keyword: '人と話すのが\n好き', sub: 'COMMUNICATION' },
        { keyword: 'チームで\n勝ちたい', sub: 'TEAMWORK' },
        { keyword: '素直に\n学べる', sub: 'GROWTH' },
        { keyword: '仲間を\n大切にできる', sub: 'CARE' },
      ].map((t) => (
        <div class="who-card-wrap aspect-square">
          <div class="who-card group relative bg-white/5 hover:bg-blue-600 w-full h-full flex flex-col items-center justify-center text-center transition-colors duration-500 cursor-default overflow-hidden">
            <div class="who-shine"></div>
            <p class="who-label text-blue-400 group-hover:text-blue-200 text-[12px] md:text-[16px] font-bold tracking-widest mb-2 transition-colors relative z-[1]">{t.sub}</p>
            <p class="text-xl md:text-3xl font-black leading-snug whitespace-pre-line relative z-[1]">{t.keyword}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 募集要項 -->
<section class="py-20 px-6 bg-white">
  <div class="max-w-4xl mx-auto">
    <p class="text-blue-600 font-bold text-xs tracking-widest uppercase mb-4 text-center">Requirements</p>
    <h2 class="text-3xl font-black text-center mb-12">募集要項</h2>

    <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm grid grid-cols-1 md:grid-cols-[10rem_1fr]">
      {[
        { label: '職種', value: 'モバイルイベントスタッフ / マネージャー候補' },
        { label: '種類', value: 'アルバイト / 社員' },
        { label: 'エリア', value: '関東 / 福岡' },
        { label: '仕事内容', value: '携帯代理店からイベントを受注し、商業施設等でのイベント運営やスタッフマネジメント業務' },
        { label: '給与', value: '基本給 ＋ インセンティブ（実績に応じて変動）\n※経験・能力を考慮のうえ決定' },
        { label: '給与例', value: null },
        { label: '勤務地', value: '勤務地は各イベント会場により異なります' },
        { label: '勤務時間', value: 'シフト制（現場のイベントスケジュールに準ずる）' },
        { label: '休日・休暇', value: '週休2日制 / 有給休暇 / 年末年始 / 夏季休暇' },
        { label: '待遇・福利厚生', value: '社会保険完備 / 交通費支給 / インセンティブ制度 / 研修制度あり' },
        { label: '応募資格', value: '学歴・経験不問 / 18歳以上（高校生不可）' },
      ].map((r, i) => (
        <>
          <div class={`bg-blue-600 text-white text-sm font-bold px-5 py-5 flex items-center border-b border-blue-500 ${i === 10 ? 'border-b-0' : ''}`}>
            {r.label}
          </div>
          <div class={`px-6 py-5 text-base text-gray-800 leading-relaxed border-b border-gray-100 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'} ${i === 10 ? 'border-b-0' : ''}`}>
            {r.value !== null ? (
              <span class="whitespace-pre-line">{r.value}</span>
            ) : (
              <span>
                入社1年目：基本給22万 ＋ インセンティブ20万（月収例 約42万円）<br /><br />
                入社3年目：基本給27万 ＋ インセンティブ30万（月収例 約57万円）<br />
                <span class="text-sm text-gray-500 mt-2 block">※社員の場合</span>
                <span class="text-sm text-gray-500 mt-1 block">※インセンティブは獲得件数・会場規模に応じた歩合制。5段階の等級制度で昇格ルートも明確。</span>
              </span>
            )}
          </div>
        </>
      ))}
    </div>
  </div>
</section>

<!-- 選考フロー -->
<section class="py-20 px-6 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <p class="text-blue-600 font-bold text-xs tracking-widest uppercase mb-4 text-center">Flow</p>
    <h2 class="text-3xl font-black text-center mb-12">選考フロー</h2>
    <div class="flex items-start justify-center gap-2 md:gap-6">
      {[
        { step: '01', label: 'エントリー', sub: 'フォームから応募' },
        { step: '02', label: '面接', sub: 'オンラインまたは対面' },
        { step: '03', label: '内定', sub: 'ご入社日を相談' },
      ].map((f, i) => (
        <>
          <div class="flex flex-col items-center text-center w-24 md:w-32">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex flex-col items-center justify-center text-white flex-shrink-0">
              <span class="text-xs font-bold text-blue-200">STEP</span>
              <span class="text-lg font-black">{f.step}</span>
            </div>
            <p class="font-bold text-gray-800 mt-3">{f.label}</p>
            <p class="text-xs text-gray-500 mt-1">{f.sub}</p>
          </div>
          {i < 2 && <span class="text-blue-300 font-bold text-2xl flex-shrink-0 mt-5">→</span>}
        </>
      ))}
    </div>
  </div>
</section>

<!-- エントリーフォーム -->
<section class="py-20 px-6 bg-gray-950 text-white">
  <div class="max-w-2xl mx-auto">
    <p class="text-blue-400 font-bold text-xs tracking-widest uppercase mb-4 text-center">Entry</p>
    <h2 class="text-3xl font-black text-center mb-4">エントリーはこちら</h2>
    <p class="text-gray-400 text-center text-sm mb-12">入力いただいた情報は採用目的のみに使用します。</p>

    <form id="entryForm" class="space-y-5">
      <div id="formError" class="hidden bg-red-500/20 border border-red-500/40 text-red-300 text-sm rounded-xl px-4 py-3">
        送信に失敗しました。時間をおいて再度お試しください。
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">お名前 <span class="text-red-400">*</span></label>
          <input type="text" name="name" required placeholder="橋本 章平"
            class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition" />
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">フリガナ <span class="text-red-400">*</span></label>
          <input type="text" name="kana" required placeholder="ハシモト ショウヘイ"
            class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">メールアドレス <span class="text-red-400">*</span></label>
          <input type="email" name="email" required placeholder="example@email.com"
            class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition" />
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">電話番号 <span class="text-red-400">*</span></label>
          <input type="tel" name="tel" required placeholder="090-0000-0000"
            class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">年齢</label>
          <input type="number" name="age" placeholder="25"
            class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition" />
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">希望職種</label>
          <select name="position" class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition">
            <option class="text-gray-900">イベントスタッフ</option>
            <option class="text-gray-900">マネージャー候補</option>
            <option class="text-gray-900">どちらでも可</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">希望種類</label>
          <select name="type" class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition">
            <option class="text-gray-900">アルバイト</option>
            <option class="text-gray-900">社員</option>
            <option class="text-gray-900">どちらでも可</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">希望勤務地</label>
          <select name="location" class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition">
            <option class="text-gray-900">東京</option>
            <option class="text-gray-900">福岡</option>
            <option class="text-gray-900">どちらでも可</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase">志望動機・自己PR</label>
        <textarea name="message" rows="4" placeholder="応募のきっかけや、自己PRをご記入ください"
          class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:bg-white/15 transition resize-none"></textarea>
      </div>
      <button type="submit" id="submitBtn"
        class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl transition-all duration-300 hover:shadow-[0_0_30px_rgba(96,165,250,0.4)] text-base">
        エントリーする →
      </button>
      <p class="text-xs text-gray-600 text-center">送信後、3営業日以内にご連絡いたします。</p>
    </form>

    <script>
      // ── Who We Want カード：シャイン方向・タイミングをランダム化 ──
      (function () {
        // グロータイミングのランダム化（ambient）
        document.querySelectorAll('.who-card-wrap').forEach(wrap => {
          wrap.style.animationDelay = (Math.random() * 6).toFixed(2) + 's';
        });

        // ラベル発光：1つずつランダム、同時発光なし
        const labels = Array.from(document.querySelectorAll('.who-label'));
        let lastLabelIdx = -1;
        function glowNext() {
          let idx;
          do { idx = Math.floor(Math.random() * labels.length); } while (idx === lastLabelIdx);
          lastLabelIdx = idx;
          const lbl = labels[idx];
          lbl.classList.add('glowing');
          setTimeout(() => {
            lbl.classList.remove('glowing');
            setTimeout(glowNext, 800 + Math.random() * 2200);
          }, 2500);
        }
        setTimeout(glowNext, 1200 + Math.random() * 2000);

        // 光の筋：1本ずつランダム、同時発光なし
        const shines = Array.from(document.querySelectorAll('.who-shine'));
        let lastShineIdx = -1;
        function shineNext() {
          let idx;
          do { idx = Math.floor(Math.random() * shines.length); } while (idx === lastShineIdx);
          lastShineIdx = idx;
          const el = shines[idx];
          el.classList.remove('shine-active');
          void el.offsetWidth; // アニメーションリセット
          el.classList.add('shine-active');
          el.addEventListener('animationend', function handler() {
            el.removeEventListener('animationend', handler);
            el.classList.remove('shine-active');
            setTimeout(shineNext, 800 + Math.random() * 2500);
          }, { once: true });
        }
        setTimeout(shineNext, 800 + Math.random() * 2000);
      })();
    </script>

    <script>
      document.getElementById('entryForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const errBox = document.getElementById('formError');
        btn.textContent = '送信中...';
        btn.disabled = true;
        errBox.classList.add('hidden');

        const f = new FormData(e.target);
        const data = Object.fromEntries(f.entries());

        try {
          const params = new URLSearchParams(data);
          await fetch('https://script.google.com/macros/s/AKfycbzH4z-YGU85Y8M75R1mMlGA3hfOeVdLgiRDFJKIa0os69NI9iAFWI-paAEqRDtUz_qB/exec', {
            method: 'POST',
            mode: 'no-cors',
            body: params,
          });
          window.location.href = '/thanks';
        } catch {
          btn.textContent = 'エントリーする →';
          btn.disabled = false;
          errBox.classList.remove('hidden');
          errBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    </script>
  </div>
</section>

</Layout>
